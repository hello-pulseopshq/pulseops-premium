{%- comment -%}
  SP Demo — resolves the brand/store name shown in header and footer.
  Returns the registered demo brand for demo verticals; otherwise shop.name.

  Identity (brand name + demo product handle) lives in sp-pack-registry.
  On the cart page (which has no template suffix) the demo brand is only used
  when every line item is the demo product, so a real merchant cart is unaffected.
{%- endcomment -%}
{%- liquid
  capture sp_demo_brand_name
    render 'sp-pack-registry', field: 'brand_name'
  endcapture

  if sp_demo_brand_name == blank and request.page_type == 'cart' and cart.item_count > 0
    capture sp_demo_cart_handle
      render 'sp-pack-registry', field: 'product_handle', vertical: 'supplement'
    endcapture
    capture sp_demo_cart_brand
      render 'sp-pack-registry', field: 'brand_name', vertical: 'supplement'
    endcapture
    if sp_demo_cart_handle != blank
      assign sp_demo_brand_only = true
      for item in cart.items
        unless item.product.handle == sp_demo_cart_handle
          assign sp_demo_brand_only = false
          break
        endunless
      endfor
      if sp_demo_brand_only
        assign sp_demo_brand_name = sp_demo_cart_brand
      endif
    endif
  endif

  if sp_demo_brand_name == blank
    assign sp_demo_brand_name = shop.name
  endif

  echo sp_demo_brand_name
-%}
