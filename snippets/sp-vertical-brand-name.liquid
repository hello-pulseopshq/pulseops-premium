{%- comment -%}
  SP Vertical — resolves the brand/store name shown in header and footer.
  Returns the registered vertical brand for vertical templates; otherwise shop.name.

  Identity (brand name + product handle) lives in sp-pack-registry.
  On the cart page (which has no template suffix) the vertical brand is only used
  when every line item is the registered vertical product, so a real merchant cart is unaffected.
{%- endcomment -%}
{%- liquid
  capture sp_vertical_brand_name
    render 'sp-pack-registry', field: 'brand_name'
  endcapture

  if sp_vertical_brand_name == blank and request.page_type == 'cart' and cart.item_count > 0
    capture sp_vertical_cart_handle
      render 'sp-pack-registry', field: 'product_handle', vertical: 'supplement'
    endcapture
    capture sp_vertical_cart_brand
      render 'sp-pack-registry', field: 'brand_name', vertical: 'supplement'
    endcapture
    if sp_vertical_cart_handle != blank
      assign sp_vertical_brand_only = true
      for item in cart.items
        unless item.product.handle == sp_vertical_cart_handle
          assign sp_vertical_brand_only = false
          break
        endunless
      endfor
      if sp_vertical_brand_only
        assign sp_vertical_brand_name = sp_vertical_cart_brand
      endif
    endif
  endif

  if sp_vertical_brand_name == blank
    assign sp_vertical_brand_name = shop.name
  endif

  echo sp_vertical_brand_name
-%}
