{% comment %}
  Shared trust / benefit icon SVG.
  Accepts: icon (check, secure, shipping, returns, science, shield, guarantee)
{% endcomment %}
{%- case icon -%}
  {%- when 'secure' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <rect x="4" y="10" width="16" height="11" rx="2"></rect>
      <path d="M8 10V7a4 4 0 0 1 8 0v3"></path>
    </svg>
  {%- when 'shipping' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path d="M1.5 4.5h12v9h-12z"></path>
      <path d="M13.5 8.5h4l3 3v2h-7z"></path>
      <circle cx="6" cy="16.5" r="2"></circle>
      <circle cx="17.5" cy="16.5" r="2"></circle>
    </svg>
  {%- when 'returns' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path d="M7 7H3v4"></path>
      <path d="M3 11a8.5 8.5 0 1 1 2.5 6"></path>
      <path d="M8.5 20.5l-3 1.5"></path>
    </svg>
  {%- when 'science' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path d="M20 4.5C11 4.5 5 9.4 5 15.8c0 2.4 1.4 4.7 3.8 5.7 5.5 2.2 11.7-2.1 11.7-9.3 0-2.2-.3-5-0.5-7.7z"></path>
      <path d="M8 16.5c2.7-.2 5.1-1.7 7.3-4.3"></path>
    </svg>
  {%- when 'shield' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path d="M12 2.5 4.5 5.5v6.2c0 4.5 2.8 8.6 7.5 9.8 4.7-1.2 7.5-5.3 7.5-9.8V5.5z"></path>
      <path d="m8.8 12.1 2.2 2.3 4.3-4.4"></path>
    </svg>
  {%- when 'guarantee' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path d="M12 2.5 4.5 5.5v6.2c0 4.5 2.8 8.6 7.5 9.8 4.7-1.2 7.5-5.3 7.5-9.8V5.5z"></path>
      <path d="m8.8 12.1 2.2 2.3 4.3-4.4"></path>
    </svg>
  {%- when 'star' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path d="M12 3.8l2.1 4.3 4.7.7-3.4 3.3.8 4.7-4.2-2.2-4.2 2.2.8-4.7-3.4-3.3 4.7-.7z"></path>
    </svg>
  {%- when 'check' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
      <path d="m5.5 12.2 4.1 4.1 9-9"></path>
    </svg>
  {%- else -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
      <path d="m5.5 12.2 4.1 4.1 9-9"></path>
    </svg>
{%- endcase -%}
