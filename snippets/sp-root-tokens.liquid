{%- comment -%}
  SP Root Tokens — all SP-owned CSS custom properties for the global :root scope.

  Rendered once from layout/theme.liquid inside Dawn's existing {% style %} :root
  block. Keeping these here (instead of inline in theme.liquid) minimises the SP
  footprint inside a Dawn-owned file, so theme.liquid stays easy to diff/merge
  against upstream Dawn.

  Output is raw CSS custom-property declarations only (no selector wrapper).
  Custom-property declaration order is irrelevant to the cascade, so these may
  live after the Dawn tokens without changing rendered values.
{%- endcomment -%}
--sp-image-placeholder-alpha: {{ settings.sp_image_placeholder_strength | divided_by: 100.0 }};
--sp-image-reveal-duration: 320ms;
{%- if settings.sp_image_shadow == 'elevated' -%}
  --sp-image-shadow: var(--media-shadow-horizontal-offset) var(--media-shadow-vertical-offset) var(--media-shadow-blur-radius) rgba(var(--color-shadow), var(--media-shadow-opacity));
{%- elsif settings.sp_image_shadow == 'subtle' -%}
  --sp-image-shadow: 0 0.2rem 1.2rem rgba(var(--color-shadow), calc(var(--media-shadow-opacity) * 0.65));
{%- else -%}
  --sp-image-shadow: none;
{%- endif -%}

--sp-surface-alt-opacity: {{ settings.sp_surface_alt_opacity | default: 4 | divided_by: 100.0 }};
--sp-surface-accent-opacity: {{ settings.sp_surface_accent_opacity | default: 10 | divided_by: 100.0 }};
--sp-width-wide-offset: {{ settings.sp_width_wide_offset | default: 80 | divided_by: 10.0 }}rem;
--sp-section-padding-inline: {{ settings.sp_section_padding_inline | default: 16 | divided_by: 10.0 }}rem;
--sp-section-padding-inline-mobile: {{ settings.sp_section_padding_inline_mobile | default: 12 | divided_by: 10.0 }}rem;
--sp-emphasis-elevated-opacity: {{ settings.sp_emphasis_elevated_opacity | default: 8 | divided_by: 100.0 }};
--sp-divider-opacity: {{ settings.sp_divider_opacity | default: 12 | divided_by: 100.0 }};
--sp-section-feature-padding: {{ settings.sp_section_feature_padding | default: 16 | divided_by: 10.0 }}rem;
--sp-section-feature-radius: var(--media-radius);

{%- case settings.sp_motion_style -%}
  {%- when 'disabled' -%}
    --sp-motion-duration: 0ms;
    --sp-motion-duration-fast: 0ms;
    --sp-motion-reveal-distance: 0rem;
    --sp-motion-stagger-delay: 0ms;
    --sp-motion-hover-lift: 0rem;
    --sp-motion-hover-shadow: 0;
    --sp-motion-image-scale: 1;
    --sp-motion-button-shift: 0rem;
  {%- when 'minimal' -%}
    --sp-motion-duration: 400ms;
    --sp-motion-duration-fast: 240ms;
    --sp-motion-reveal-distance: 1.2rem;
    --sp-motion-stagger-delay: 60ms;
    --sp-motion-hover-lift: 0.2rem;
    --sp-motion-hover-shadow: 0.08;
    --sp-motion-image-scale: 1.02;
    --sp-motion-button-shift: 0.06rem;
  {%- when 'premium' -%}
    --sp-motion-duration: 700ms;
    --sp-motion-duration-fast: 380ms;
    --sp-motion-reveal-distance: 2.8rem;
    --sp-motion-stagger-delay: 120ms;
    --sp-motion-hover-lift: 0.5rem;
    --sp-motion-hover-shadow: 0.18;
    --sp-motion-image-scale: 1.03;
    --sp-motion-button-shift: 0.14rem;
  {%- else -%}
    --sp-motion-duration: 550ms;
    --sp-motion-duration-fast: 320ms;
    --sp-motion-reveal-distance: 2rem;
    --sp-motion-stagger-delay: 80ms;
    --sp-motion-hover-lift: 0.35rem;
    --sp-motion-hover-shadow: 0.12;
    --sp-motion-image-scale: 1.03;
    --sp-motion-button-shift: 0.1rem;
{%- endcase -%}
