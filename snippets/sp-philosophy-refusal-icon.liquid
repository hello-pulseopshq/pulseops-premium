{%- comment -%}
  Inline SVG icons for Formulation Philosophy refusal principles.
  Usage: {% render 'sp-philosophy-refusal-icon', icon: block.settings.icon %}
{%- endcomment -%}
{%- case icon -%}
  {%- when 'prohibited' -%}
    <svg class="sp-editorial-differentiation__refusal-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <circle cx="12" cy="12" r="9"></circle>
      <path d="m7.5 7.5 9 9"></path>
    </svg>
  {%- when 'not_equal' -%}
    <svg class="sp-editorial-differentiation__refusal-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M5 9h14M5 15h14"></path>
      <path d="m16 6-8 12"></path>
    </svg>
  {%- when 'shield' -%}
    <svg class="sp-editorial-differentiation__refusal-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M12 3 4 7v6c0 5 3.5 8 8 8s8-3 8-8V7l-8-4Z"></path>
    </svg>
  {%- when 'megaphone' -%}
    <svg class="sp-editorial-differentiation__refusal-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M4 10v4h4l5 4V6L8 10H4Z"></path>
      <path d="M16 8.5a4.5 4.5 0 0 1 0 7"></path>
      <path d="m18 6 3 12"></path>
    </svg>
  {%- when 'package' -%}
    <svg class="sp-editorial-differentiation__refusal-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M3 7.5 12 3l9 4.5v9L12 21l-9-4.5v-9Z"></path>
      <path d="M12 12 21 7.5M12 12v9M12 12 3 7.5"></path>
      <path d="m6 10 12 6"></path>
    </svg>
  {%- else -%}
    <svg class="sp-editorial-differentiation__refusal-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <circle cx="12" cy="12" r="9"></circle>
      <path d="m7.5 7.5 9 9"></path>
    </svg>
{%- endcase -%}
