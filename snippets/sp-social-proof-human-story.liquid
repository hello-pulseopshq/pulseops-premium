{%- comment -%}
  Human story — portrait-led editorial proof chapter.

  Accepts:
  - section: {Object} parent section
{%- endcomment -%}

{%- liquid
  assign slide_count = 0
  for block in section.blocks
    assign review_text_stripped = block.settings.review_text | strip_html | strip
    assign customer_name_stripped = block.settings.customer_name | strip
    if review_text_stripped != blank or customer_name_stripped != blank
      assign slide_count = slide_count | plus: 1
    endif
  endfor

  assign auto_rotate_ms = section.settings.stage_auto_rotate | default: 6 | times: 1000
  assign eyebrow_stripped = section.settings.eyebrow | strip
  assign heading_stripped = section.settings.heading | strip_html | strip
  assign verification_stripped = section.settings.verification_note | strip

  assign story_image_alt = section.settings.story_image_alt | strip
  if story_image_alt == blank and section.settings.story_image != blank
    assign story_image_alt = section.settings.story_image.alt | escape
  endif
  if story_image_alt == blank
    assign story_image_alt = 'Customer lifestyle portrait' | escape
  endif
-%}

<div class="sp-social-proof__human-story sp-editorial-chapter sp-editorial-chapter--spacing-standard sp-editorial-chapter--handoff-in sp-editorial-chapter--handoff-out">
  {%- if section.settings.story_image != blank -%}
    <div class="sp-social-proof__human-story-portrait{% render 'sp-motion-class', type: 'fade-up' %}">
      <div class="sp-social-proof__human-story-portrait-frame">
        {{
          section.settings.story_image
          | image_url: width: 2200
          | image_tag:
            widths: '550, 750, 1100, 1500, 1800, 2200',
            sizes: '(min-width: 990px) 48vw, 100vw',
            alt: story_image_alt,
            loading: 'eager',
            fetchpriority: 'high',
            class: 'sp-image sp-social-proof__human-story-portrait-image'
        }}
      </div>
    </div>
  {%- endif -%}

  <div class="sp-social-proof__human-story-panel{% render 'sp-motion-class', type: 'fade-up' %}">
    {%- if eyebrow_stripped != blank or heading_stripped != blank -%}
      <header class="sp-social-proof__human-story-intro">
        {%- if eyebrow_stripped != blank -%}
          <p class="sp-social-proof__human-story-eyebrow sp-editorial-type--caption caption-with-letter-spacing">
            {{ section.settings.eyebrow | escape }}
          </p>
        {%- endif -%}

        {%- if heading_stripped != blank -%}
          <h2 class="sp-social-proof__human-story-lead sp-editorial-type--statement">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div
      class="sp-social-proof__human-story-stage"
      data-sp-testimonial-stage
      data-auto-rotate="{{ auto_rotate_ms }}"
      {% if slide_count > 1 %}
        role="region"
        aria-roledescription="carousel"
        aria-label="{{ section.settings.eyebrow | default: 'Human proof' | escape }}"
      {% endif %}
    >
      <div class="sp-social-proof__stage-viewport">
        <div class="sp-social-proof__stage-track" data-sp-stage-track>
          {%- assign active_index = 0 -%}
          {%- for block in section.blocks -%}
            {%- liquid
              assign review_text_stripped = block.settings.review_text | strip_html | strip
              assign customer_name_stripped = block.settings.customer_name | strip
              assign customer_title_stripped = block.settings.customer_title | strip
            -%}
            {%- if review_text_stripped != blank or customer_name_stripped != blank -%}
              {%- assign active_index = active_index | plus: 1 -%}
              <article
                class="sp-social-proof__stage-slide sp-social-proof__human-story-slide{% if active_index == 1 %} is-active{% endif %}"
                data-sp-stage-slide
                id="HumanStorySlide-{{ section.id }}-{{ active_index }}"
                {{ block.shopify_attributes }}
                {% unless active_index == 1 %}hidden{% endunless %}
                aria-hidden="{% if active_index == 1 %}false{% else %}true{% endif %}"
              >
                {%- if review_text_stripped != blank -%}
                  <blockquote class="sp-social-proof__human-story-quote sp-editorial-type--quote">
                    <div class="sp-social-proof__human-story-quote-text rte">
                      {{ block.settings.review_text }}
                    </div>
                  </blockquote>
                {%- endif -%}

                {%- if customer_name_stripped != blank or customer_title_stripped != blank -%}
                  <footer class="sp-social-proof__human-story-attribution">
                    {%- if customer_name_stripped != blank -%}
                      <cite class="sp-social-proof__human-story-name">
                        {{ block.settings.customer_name | escape }}
                      </cite>
                    {%- endif -%}
                    {%- if customer_title_stripped != blank -%}
                      <p class="sp-social-proof__human-story-context">
                        {{ block.settings.customer_title | escape }}
                      </p>
                    {%- endif -%}
                  </footer>
                {%- endif -%}
              </article>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      {%- if slide_count > 1 -%}
        <div
          class="sp-social-proof__human-story-dots"
          role="group"
          aria-label="Story navigation"
        >
          {%- assign dot_index = 0 -%}
          {%- for block in section.blocks -%}
            {%- liquid
              assign review_text_stripped = block.settings.review_text | strip_html | strip
              assign customer_name_stripped = block.settings.customer_name | strip
            -%}
            {%- if review_text_stripped != blank or customer_name_stripped != blank -%}
              {%- assign dot_index = dot_index | plus: 1 -%}
              <button
                type="button"
                class="sp-social-proof__human-story-dot{% if dot_index == 1 %} is-active{% endif %}"
                data-sp-stage-dot
                data-slide-index="{{ dot_index | minus: 1 }}"
                aria-label="Story {{ dot_index }} of {{ slide_count }}"
                {% if dot_index == 1 %}aria-current="true"{% endif %}
              >
                <span class="visually-hidden">Story {{ dot_index }} of {{ slide_count }}</span>
              </button>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      <p class="visually-hidden" aria-live="polite" data-sp-stage-live></p>
    </div>

    {%- if verification_stripped != blank -%}
      <p class="sp-social-proof__human-story-verification">
        {{ section.settings.verification_note | escape }}
      </p>
    {%- elsif slide_count > 0 -%}
      {%- assign first_block = section.blocks.first -%}
      {%- if first_block.settings.verified -%}
        <p class="sp-social-proof__human-story-verification">Verified purchaser</p>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>
