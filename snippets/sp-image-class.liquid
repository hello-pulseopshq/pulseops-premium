{%- comment -%}
  SP Image Experience — class helper for Liquid templates.

  Usage:
    <div class="my-block{% render 'sp-image-class', type: 'frame-landscape' %}">
    {{ image | image_tag: class: 'my-img' | append: render output from frame-image }}

  Types:
    frame | frame-square | frame-landscape | frame-portrait | frame-wide
    frame-adapt | frame-custom | frame-circle | frame-intrinsic | frame-logo
    image | image-reveal | image-contain
{%- endcomment -%}
{%- liquid
  assign output = ''

  case type
    when 'frame'
      assign output = ' sp-media-frame'
    when 'frame-square'
      assign output = ' sp-media-frame sp-media-frame--square'
    when 'frame-landscape'
      assign output = ' sp-media-frame sp-media-frame--landscape'
    when 'frame-portrait'
      assign output = ' sp-media-frame sp-media-frame--portrait'
    when 'frame-wide'
      assign output = ' sp-media-frame sp-media-frame--wide'
    when 'frame-adapt'
      assign output = ' sp-media-frame sp-media-frame--adapt'
    when 'frame-custom'
      assign output = ' sp-media-frame sp-media-frame--custom'
    when 'frame-circle'
      assign output = ' sp-media-frame sp-media-frame--circle sp-media-frame--intrinsic'
    when 'frame-intrinsic'
      assign output = ' sp-media-frame sp-media-frame--intrinsic'
    when 'frame-logo'
      assign output = ' sp-media-frame sp-media-frame--logo sp-media-frame--intrinsic'
    when 'image'
      assign output = ' sp-image'
    when 'image-reveal'
      if settings.sp_image_progressive_reveal
        assign output = ' sp-image sp-image-reveal'
      else
        assign output = ' sp-image'
      endif
    when 'image-contain'
      assign output = ' sp-image sp-image--contain'
  endcase

  echo output
-%}
