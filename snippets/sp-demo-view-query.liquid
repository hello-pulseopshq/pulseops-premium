{%- comment -%}
  SP Demo — returns the ?view=<suffix> query string for the active demo vertical,
  or blank when no demo is active (production stores: byte-identical empty output).

  Used by header logo/cart links and footer brand link to keep users inside the
  supplement (or other pack) demo experience.

  Cart-page fallback: when the cart contains only the demo product, treat the
  session as supplement even though cart has no template suffix.
{%- endcomment -%}
{%- liquid
  capture sp_demo_active
    render 'sp-pack-registry', field: 'active'
  endcapture

  if sp_demo_active == blank and request.page_type == 'cart' and cart.item_count > 0
    capture sp_demo_cart_handle
      render 'sp-pack-registry', field: 'product_handle', vertical: 'supplement'
    endcapture
    if sp_demo_cart_handle != blank
      assign sp_demo_brand_only = true
      for item in cart.items
        unless item.product.handle == sp_demo_cart_handle
          assign sp_demo_brand_only = false
          break
        endunless
      endfor
      if sp_demo_brand_only
        assign sp_demo_active = 'supplement'
      endif
    endif
  endif

  assign sp_demo_view_query = ''
  if sp_demo_active != blank
    assign sp_demo_view_query = '?view=' | append: sp_demo_active
  endif

  echo sp_demo_view_query
-%}
