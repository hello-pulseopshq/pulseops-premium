{%- comment -%}
  SP Hero — media rendering (fallback image / responsive picture / placeholder).

  Extracted from sections/sp-hero.liquid to keep the hero section's markup focused.
  All inputs are passed explicitly so the snippet is render-scope safe.

  Parameters:
    sp_hero_fallback        — boolean, render the registry fallback image
    sp_hero_fallback_image  — asset filename for the fallback image (from registry)
    desktop_image           — image object (or blank)
    mobile_image            — image object (or blank)
    alt_text                — escaped alt text
    hero_image_classes      — class string for the <img>
    image_loading           — 'eager' | 'lazy'
    image_fetch_priority    — 'high' | 'auto' | 'low'
{%- endcomment -%}
{%- if sp_hero_fallback and sp_hero_fallback_image != blank -%}
  <img
    src="{{ sp_hero_fallback_image | asset_url }}"
    alt="{{ alt_text }}"
    class="{{ hero_image_classes }}"
    loading="{{ image_loading }}"
    fetchpriority="{{ image_fetch_priority }}"
    width="800"
    height="1000"
    decoding="async"
  >
{%- elsif mobile_image != blank -%}
  <picture>
    {%- if desktop_image != blank -%}
      <source
        media="(min-width: 750px)"
        srcset="
          {{ desktop_image | image_url: width: 750 }} 750w,
          {{ desktop_image | image_url: width: 1100 }} 1100w,
          {{ desktop_image | image_url: width: 1500 }} 1500w,
          {{ desktop_image | image_url: width: 2200 }} 2200w
        "
        sizes="(min-width: 990px) calc((100vw - 10rem) / 2), (min-width: 750px) calc((100vw - 8rem) / 2), 100vw"
      >
    {%- endif -%}

    {{
      mobile_image
      | image_url: width: 1600
      | image_tag:
        widths: '375,550,750,900,1100,1500,1600',
        sizes: '100vw',
        alt: alt_text,
        loading: image_loading,
        fetchpriority: image_fetch_priority,
        class: hero_image_classes
    }}
  </picture>
{%- else -%}
  <span class="sp-image-placeholder" aria-hidden="true">
    {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
  </span>
{%- endif -%}
