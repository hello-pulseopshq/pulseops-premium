{% comment %}
  CTA trust stack below hero button.
  Accepts: section
{% endcomment %}

{%- if section.settings.show_cta_trust_stack -%}
  {%- assign stack_blocks = section.blocks | where: 'type', 'cta_trust_item' -%}
  {%- if stack_blocks.size > 0 -%}
    <ul class="sp-hero__trust-stack sp-hero__slot--trust-stack list-unstyled{% render 'sp-motion-class', type: 'stagger-item' %}" role="list">
      {%- for block in stack_blocks -%}
        {%- if block.settings.text != blank -%}
          <li class="sp-hero__trust-stack-item caption" {{ block.shopify_attributes }}>
            <span class="sp-hero__trust-stack-icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'guarantee' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M12 2.5 4.5 5.5v6.2c0 4.5 2.8 8.6 7.5 9.8 4.7-1.2 7.5-5.3 7.5-9.8V5.5z"></path>
                    <path d="m8.8 12.1 2.2 2.3 4.3-4.4"></path>
                  </svg>
                {%- when 'shipping' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M1.5 4.5h12v9h-12z"></path>
                    <path d="M13.5 8.5h4l3 3v2h-7z"></path>
                    <circle cx="6" cy="16.5" r="2"></circle>
                    <circle cx="17.5" cy="16.5" r="2"></circle>
                  </svg>
                {%- when 'returns' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M7 7H3v4"></path>
                    <path d="M3 11a8.5 8.5 0 1 1 2.5 6"></path>
                    <path d="M8.5 20.5l-3 1.5"></path>
                  </svg>
                {%- when 'secure' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <rect x="4" y="10" width="16" height="11" rx="2"></rect>
                    <path d="M8 10V7a4 4 0 0 1 8 0v3"></path>
                  </svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="m5.5 12.2 4.1 4.1 9-9"></path>
                  </svg>
              {%- endcase -%}
            </span>
            {{ block.settings.text | escape }}
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  {%- endif -%}
{%- endif -%}
