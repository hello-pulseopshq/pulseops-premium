{{ 'sp-editorial-differentiation.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign top_extra = 0
  case section.settings.top_spacing
    when 'small'
      assign top_extra = 12
    when 'medium'
      assign top_extra = 28
    when 'large'
      assign top_extra = 48
  endcase

  assign bottom_extra = 0
  case section.settings.bottom_spacing
    when 'small'
      assign bottom_extra = 12
    when 'medium'
      assign bottom_extra = 28
    when 'large'
      assign bottom_extra = 48
  endcase

  assign pad_top = section.settings.padding_top | plus: top_extra
  assign pad_bottom = section.settings.padding_bottom | plus: bottom_extra
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ pad_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ pad_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ pad_top }}px;
      padding-bottom: {{ pad_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign shell_class = 'sp-editorial-differentiation-shell sp-editorial-differentiation-shell--tone-' | append: section.settings.background_tone

  assign root_class = 'sp-editorial-differentiation'
  assign root_class = root_class | append: ' sp-editorial-differentiation--image-' | append: section.settings.image_position
  assign root_class = root_class | append: ' sp-editorial-differentiation--top-spacing-' | append: section.settings.top_spacing
  assign root_class = root_class | append: ' sp-editorial-differentiation--bottom-spacing-' | append: section.settings.bottom_spacing

  if section.settings.show_proof_numbers
    assign root_class = root_class | append: ' sp-editorial-differentiation--show-proof-numbers'
  endif

  if section.settings.show_cta_divider
    assign root_class = root_class | append: ' sp-editorial-differentiation--show-cta-divider'
  endif

  assign image_alt = section.settings.image_alt | strip
  if image_alt == blank and section.settings.image != blank
    assign image_alt = section.settings.image.alt | escape
  endif
  if image_alt == blank
    assign image_alt = section.settings.heading | strip_html | escape
  endif

  assign show_cta = false
  if section.settings.button_label != blank and section.settings.button_link != blank
    assign show_cta = true
  endif
-%}

{% render 'sp-section-hierarchy-open', section: section, anchor_id: 'sp-differentiation', extra_class: shell_class %}
  <div
    class="{{ root_class }}"
    {% if section.settings.heading != blank %}
      aria-label="{{ section.settings.heading | strip_html | escape }}"
    {% else %}
      aria-label="Editorial differentiation"
    {% endif %}
  >
    {%- if section.settings.show_top_divider -%}
      <div class="sp-editorial-differentiation__chapter-divider" aria-hidden="true"></div>
    {%- endif -%}

    <div class="sp-editorial-differentiation__composition{% render 'sp-motion-class', type: 'stagger' %}" data-sp-stagger>
      <div class="sp-editorial-differentiation__media{% render 'sp-motion-class', type: 'stagger-item' %}">
        {%- if section.settings.image != blank -%}
          <div class="sp-editorial-differentiation__media-frame">
            {{
              section.settings.image
              | image_url: width: 2200
              | image_tag:
                widths: '550, 750, 1100, 1500, 1800, 2200',
                sizes: '(min-width: 990px) calc((100vw - 8rem) / 2), 100vw',
                alt: image_alt,
                loading: 'lazy',
                class: 'sp-image sp-editorial-differentiation__media-image'
            }}
          </div>
        {%- else -%}
          <div class="sp-editorial-differentiation__media-frame sp-editorial-differentiation__media-frame--placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      <div class="sp-editorial-differentiation__story{% render 'sp-motion-class', type: 'stagger-item' %}">
        <div class="sp-editorial-differentiation__story-copy">
          {%- if section.settings.eyebrow != blank -%}
            <p class="sp-editorial-differentiation__eyebrow caption-with-letter-spacing">
              {{ section.settings.eyebrow | escape }}
            </p>
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            <h2 class="sp-editorial-differentiation__heading{% render 'sp-motion-class', type: 'fade-up' %}">
              {{ section.settings.heading }}
            </h2>
          {%- endif -%}

          {%- if section.settings.body != blank -%}
            <div class="sp-editorial-differentiation__body rte">
              {{ section.settings.body }}
            </div>
          {%- endif -%}
        </div>

        {%- if section.blocks.size > 0 -%}
          <ol class="sp-editorial-differentiation__proof-list{% render 'sp-motion-class', type: 'stagger' %}" data-sp-stagger>
            {%- for block in section.blocks -%}
              {%- if block.settings.title != blank or block.settings.text != blank -%}
                <li
                  class="sp-editorial-differentiation__proof-item{% render 'sp-motion-class', type: 'stagger-item' %}"
                  {{ block.shopify_attributes }}
                >
                  {%- if section.settings.show_proof_numbers -%}
                    <span class="sp-editorial-differentiation__proof-index" aria-hidden="true"></span>
                  {%- endif -%}
                  <div class="sp-editorial-differentiation__proof-content">
                    {%- if block.settings.title != blank -%}
                      <h3 class="sp-editorial-differentiation__proof-title">{{ block.settings.title | escape }}</h3>
                    {%- endif -%}
                    {%- if block.settings.text != blank -%}
                      <p class="sp-editorial-differentiation__proof-text">{{ block.settings.text | escape }}</p>
                    {%- endif -%}
                  </div>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ol>
        {%- endif -%}

        {%- if show_cta or section.settings.trust_text != blank -%}
          <div class="sp-editorial-differentiation__cta-shell{% render 'sp-motion-class', type: 'fade-up' %}">
            {%- if section.settings.show_cta_divider -%}
              <div class="sp-editorial-differentiation__cta-divider" aria-hidden="true"></div>
            {%- endif -%}
            <div class="sp-editorial-differentiation__footer">
              {%- if show_cta -%}
                <a href="{{ section.settings.button_link }}" class="sp-editorial-differentiation__button button{% render 'sp-motion-class', type: 'hover-button' %}">
                  <span>{{ section.settings.button_label | escape }}</span>
                  <span class="sp-editorial-differentiation__button-arrow" aria-hidden="true">→</span>
                </a>
              {%- endif -%}

              {%- if section.settings.trust_text != blank -%}
                {%- render 'sp-cta-trust-row',
                  trust_text: section.settings.trust_text,
                  wrapper_class: 'sp-editorial-differentiation__trust-row'
                -%}
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
{% render 'sp-section-hierarchy-close' %}

{% schema %}
{
  "name": "SP Why Choose",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Editorial image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "default": "Why customers choose us",
      "label": "Eyebrow"
    },
    {
      "type": "richtext",
      "id": "heading",
      "default": "<p>Built for consistency, not quick fixes.</p>",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "body",
      "default": "<p>Designed around the habits people actually keep: simple dosing, clean sourcing, purposeful ingredients, and quality standards you can trust.</p>",
      "label": "Body"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "Shop now",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "trust_text",
      "default": "30-day guarantee · Secure checkout",
      "label": "Trust line"
    },
    {
      "type": "header",
      "content": "Chapter layout"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Desktop image position",
      "default": "right",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "Top spacing",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "Bottom spacing",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_top_divider",
      "label": "Show top chapter divider",
      "default": false
    },
    {
      "type": "select",
      "id": "background_tone",
      "label": "Background tone",
      "default": "soft",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "soft", "label": "Soft" },
        { "value": "contrast", "label": "Contrast" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_proof_numbers",
      "label": "Show proof point numbers",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_cta_divider",
      "label": "Show divider above CTA",
      "default": true
    },
    {
      "type": "header",
      "content": "Visual hierarchy"
    },
    {
      "type": "select",
      "id": "sp_surface_style",
      "label": "Surface style",
      "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "alternate", "label": "Alternate" },
        { "value": "inverse", "label": "Inverse" },
        { "value": "accent", "label": "Accent" },
        { "value": "transparent", "label": "Transparent" }
      ]
    },
    {
      "type": "select",
      "id": "sp_width_mode",
      "label": "Width mode",
      "default": "wide",
      "options": [
        { "value": "contained", "label": "Contained" },
        { "value": "wide", "label": "Wide" },
        { "value": "full", "label": "Full width" },
        { "value": "bleed", "label": "Bleed" }
      ]
    },
    {
      "type": "select",
      "id": "sp_section_emphasis",
      "label": "Section emphasis",
      "default": "normal",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "elevated", "label": "Elevated" },
        { "value": "feature", "label": "Feature" }
      ]
    },
    {
      "type": "select",
      "id": "sp_divider_style",
      "label": "Divider",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "line", "label": "Line" },
        { "value": "fade", "label": "Fade" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "proof_point",
      "name": "Proof point",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Proof point title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "default": "Supporting copy for this proof point.",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SP Why Choose",
      "blocks": [
        {
          "type": "proof_point",
          "settings": {
            "title": "Clean sourcing",
            "text": "Carefully selected ingredients with no artificial colors, synthetic fillers, or unnecessary compounds."
          }
        },
        {
          "type": "proof_point",
          "settings": {
            "title": "Purposeful formulation",
            "text": "Each ingredient has a clear role across energy, gut support, recovery, and immune health."
          }
        },
        {
          "type": "proof_point",
          "settings": {
            "title": "Daily simplicity",
            "text": "One easy ritual designed to replace complicated stacks and inconsistent supplement routines."
          }
        },
        {
          "type": "proof_point",
          "settings": {
            "title": "Quality standards",
            "text": "Produced with quality controls, batch discipline, and standards customers can feel confident in."
          }
        }
      ]
    }
  ]
}
{% endschema %}
