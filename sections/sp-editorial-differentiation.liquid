{{ 'sp-editorial-differentiation.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign top_extra = 0
  case section.settings.top_spacing
    when 'small'
      assign top_extra = 12
    when 'medium'
      assign top_extra = 28
    when 'large'
      assign top_extra = 48
  endcase

  assign bottom_extra = 0
  case section.settings.bottom_spacing
    when 'small'
      assign bottom_extra = 12
    when 'medium'
      assign bottom_extra = 28
    when 'large'
      assign bottom_extra = 48
  endcase

  assign pad_top = section.settings.padding_top | plus: top_extra
  assign pad_bottom = section.settings.padding_bottom | plus: bottom_extra

  assign presentation = section.settings.presentation | default: 'split_proof'
  assign shell_class = 'sp-editorial-differentiation-shell sp-editorial-differentiation-shell--tone-' | append: section.settings.background_tone

  assign image_alt = section.settings.image_alt | strip
  if image_alt == blank and section.settings.image != blank
    assign image_alt = section.settings.image.alt | escape
  endif
  if image_alt == blank
    assign image_alt = section.settings.heading | strip_html | escape
  endif

  assign show_cta = false
  if section.settings.button_label != blank and section.settings.button_link != blank
    assign show_cta = true
  endif

  assign philosophy_closing_stripped = section.settings.philosophy_closing_line | strip
  assign governing_question_stripped = section.settings.governing_question | strip
  assign refusals_label_stripped = section.settings.refusals_label | strip
  assign refusals_intro_stripped = section.settings.refusals_intro | strip
  assign closing_eyebrow_stripped = section.settings.closing_eyebrow | strip
  assign closing_emphasis_stripped = section.settings.closing_emphasis | strip
  if closing_emphasis_stripped == blank
    assign closing_emphasis_stripped = philosophy_closing_stripped
  endif
  assign next_chapter_label_stripped = section.settings.next_chapter_label | strip
  assign hero_anchor_label_stripped = section.settings.hero_anchor_label | strip
  assign hero_anchor_link = section.settings.hero_anchor_link
  if hero_anchor_link == blank
    assign hero_anchor_link = '#sp-differentiation-closing'
  endif
  assign next_chapter_link = section.settings.next_chapter_link
  if next_chapter_link == blank
    assign next_chapter_link = section.settings.button_link
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ pad_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ pad_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ pad_top }}px;
      padding-bottom: {{ pad_bottom }}px;
    }
  }
{%- endstyle -%}

{% render 'sp-section-hierarchy-open', section: section, anchor_id: 'sp-differentiation', extra_class: shell_class %}
  {%- if presentation == 'philosophy_manifesto' -%}
    {%- liquid
      assign philosophy_root_class = 'sp-editorial-differentiation sp-editorial-differentiation--philosophy-manifesto'
      assign has_refusal_blocks = false
      for block in section.blocks
        if block.type == 'refusal_principle'
          assign title_stripped = block.settings.title | strip
          assign text_stripped = block.settings.text | strip
          if title_stripped != blank or text_stripped != blank
            assign has_refusal_blocks = true
            break
          endif
        endif
      endfor
      assign show_closing = false
      if closing_eyebrow_stripped != blank or section.settings.closing_headline != blank or closing_emphasis_stripped != blank or section.settings.closing_body != blank
        assign show_closing = true
      endif
      assign show_next_chapter = false
      if next_chapter_label_stripped != blank and next_chapter_link != blank
        assign show_next_chapter = true
      endif
      assign show_hero_anchor = false
      if hero_anchor_label_stripped != blank and hero_anchor_link != blank
        assign show_hero_anchor = true
      endif
    -%}
    <div
      class="{{ philosophy_root_class }}"
      {% if section.settings.heading != blank %}
        aria-label="{{ section.settings.heading | strip_html | escape }}"
      {% else %}
        aria-label="Formulation philosophy"
      {% endif %}
    >
      {%- if section.settings.show_top_divider -%}
        <div class="sp-editorial-differentiation__chapter-divider" aria-hidden="true"></div>
      {%- endif -%}

      <div class="sp-editorial-differentiation__fp-frame">
        <div class="sp-editorial-differentiation__fp-content">
          <section class="sp-editorial-differentiation__fp-spread{% render 'sp-motion-class', type: 'fade-in-quiet' %}" aria-label="Opening statement">
            <div class="sp-editorial-differentiation__fp-spread-grid">
              <header class="sp-editorial-differentiation__fp-spread-declaration">
                {%- if section.settings.eyebrow != blank -%}
                  <p class="sp-editorial-differentiation__fp-eyebrow">
                    <span class="sp-editorial-differentiation__fp-eyebrow-text">{{ section.settings.eyebrow | escape }}</span>
                    <span class="sp-editorial-differentiation__fp-eyebrow-line" aria-hidden="true"></span>
                  </p>
                {%- endif -%}

                {%- if section.settings.heading != blank -%}
                  <h2 class="sp-editorial-differentiation__fp-headline">
                    {{ section.settings.heading }}
                  </h2>
                {%- endif -%}
              </header>

              <div class="sp-editorial-differentiation__fp-spread-editorial">
                {%- if governing_question_stripped != blank -%}
                  <p class="sp-editorial-differentiation__fp-governing">
                    {{ governing_question_stripped | escape }}
                  </p>
                {%- endif -%}

                {%- if section.settings.body != blank -%}
                  <div class="sp-editorial-differentiation__fp-body">
                    {{ section.settings.body }}
                  </div>
                {%- endif -%}

                {%- if show_hero_anchor -%}
                  <p class="sp-editorial-differentiation__fp-hero-anchor">
                    <a href="{{ hero_anchor_link }}" class="sp-editorial-differentiation__fp-anchor-link">
                      <span>{{ hero_anchor_label_stripped | escape }}</span>
                      <span class="sp-editorial-differentiation__fp-anchor-arrow" aria-hidden="true">→</span>
                    </a>
                  </p>
                {%- endif -%}
              </div>

              {%- if section.settings.show_philosophy_image and section.settings.image != blank -%}
                <figure class="sp-editorial-differentiation__fp-spread-media">
                  <div class="sp-editorial-differentiation__fp-spread-media-frame">
                    {{
                      section.settings.image
                      | image_url: width: 2400
                      | image_tag:
                        widths: '550, 750, 1100, 1500, 1800, 2200, 2400',
                        sizes: '(min-width: 990px) 42vw, 100vw',
                        alt: image_alt,
                        loading: 'lazy',
                        class: 'sp-editorial-differentiation__fp-spread-media-image'
                    }}
                  </div>
                </figure>
              {%- endif -%}
            </div>
          </section>

          {%- if has_refusal_blocks -%}
            <section
              class="sp-editorial-differentiation__fp-refusals{% render 'sp-motion-class', type: 'fade-in-quiet' %}"
              {% if refusals_label_stripped != blank %}
                aria-labelledby="{{ section.id }}-refusals-label"
              {% else %}
                aria-label="Refusal principles"
              {% endif %}
            >
              {%- if refusals_label_stripped != blank -%}
                <p id="{{ section.id }}-refusals-label" class="sp-editorial-differentiation__fp-refusals-label">
                  {{ refusals_label_stripped | escape }}
                </p>
              {%- endif -%}

              <div class="sp-editorial-differentiation__fp-refusals-band">
                {%- if refusals_intro_stripped != blank -%}
                  <p class="sp-editorial-differentiation__fp-refusals-intro">
                    {{ refusals_intro_stripped | escape }}
                  </p>
                {%- endif -%}

                <ol class="sp-editorial-differentiation__fp-refusals-list">
                  {%- assign refusal_index = 0 -%}
                  {%- for block in section.blocks -%}
                    {%- if block.type == 'refusal_principle' -%}
                      {%- liquid
                        assign title_stripped = block.settings.title | strip
                        assign text_stripped = block.settings.text | strip
                        assign refusal_index = refusal_index | plus: 1
                      -%}
                      {%- if title_stripped != blank or text_stripped != blank -%}
                        <li
                          class="sp-editorial-differentiation__fp-refusal{% if block.settings.emphasize %} sp-editorial-differentiation__fp-refusal--emphasize{% endif %}"
                          {{ block.shopify_attributes }}
                        >
                          <span class="sp-editorial-differentiation__fp-refusal-index" aria-hidden="true">
                            {{ refusal_index | prepend: '0' | slice: -2, 2 }}
                          </span>
                          <span class="sp-editorial-differentiation__fp-refusal-icon" aria-hidden="true">
                            {% render 'sp-philosophy-refusal-icon', icon: block.settings.icon %}
                          </span>
                          {%- if title_stripped != blank -%}
                            <h3 class="sp-editorial-differentiation__fp-refusal-title">{{ title_stripped | escape }}</h3>
                          {%- endif -%}
                          <span class="sp-editorial-differentiation__fp-refusal-divider" aria-hidden="true"></span>
                          {%- if text_stripped != blank -%}
                            <p class="sp-editorial-differentiation__fp-refusal-text">{{ text_stripped | escape }}</p>
                          {%- endif -%}
                        </li>
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}
                </ol>
              </div>
            </section>
          {%- endif -%}

          {%- if show_closing -%}
            <section
              id="sp-differentiation-closing"
              class="sp-editorial-differentiation__fp-closing{% render 'sp-motion-class', type: 'fade-in-quiet' %}"
              {% if closing_eyebrow_stripped != blank %}
                aria-labelledby="{{ section.id }}-closing-label"
              {% else %}
                aria-label="Closing statement"
              {% endif %}
            >
              <div class="sp-editorial-differentiation__fp-closing-grid">
                <div class="sp-editorial-differentiation__fp-closing-statement">
                  {%- if closing_eyebrow_stripped != blank -%}
                    <p id="{{ section.id }}-closing-label" class="sp-editorial-differentiation__fp-closing-eyebrow">
                      {{ closing_eyebrow_stripped | escape }}
                    </p>
                  {%- endif -%}

                  {%- if section.settings.closing_headline != blank -%}
                    <h2 class="sp-editorial-differentiation__fp-closing-headline">
                      {{ section.settings.closing_headline }}
                    </h2>
                  {%- endif -%}

                  {%- if closing_emphasis_stripped != blank -%}
                    <p class="sp-editorial-differentiation__fp-closing-emphasis">
                      <em>{{ closing_emphasis_stripped | escape }}</em>
                    </p>
                  {%- endif -%}
                </div>

                {%- if section.settings.closing_body != blank -%}
                  <div class="sp-editorial-differentiation__fp-closing-support">
                    {{ section.settings.closing_body }}
                  </div>
                {%- endif -%}
              </div>
            </section>
          {%- endif -%}

          {%- if show_next_chapter -%}
            <nav class="sp-editorial-differentiation__fp-transition{% render 'sp-motion-class', type: 'fade-in-quiet' %}" aria-label="Next chapter">
              <a href="{{ next_chapter_link }}" class="sp-editorial-differentiation__fp-transition-link">
                <span>{{ next_chapter_label_stripped | escape }}</span>
                <span class="sp-editorial-differentiation__fp-transition-arrow" aria-hidden="true">↓</span>
              </a>
            </nav>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- else -%}
    {%- liquid
      assign root_class = 'sp-editorial-differentiation sp-editorial-chapter sp-editorial-chapter--cinematic sp-editorial-chapter--image-led sp-editorial-chapter--spacing-cinematic'
      assign root_class = root_class | append: ' sp-editorial-differentiation--image-' | append: section.settings.image_position
      assign root_class = root_class | append: ' sp-editorial-differentiation--top-spacing-' | append: section.settings.top_spacing
      assign root_class = root_class | append: ' sp-editorial-differentiation--bottom-spacing-' | append: section.settings.bottom_spacing

      if section.settings.show_proof_numbers
        assign root_class = root_class | append: ' sp-editorial-differentiation--show-proof-numbers'
      endif

      if section.settings.show_cta_divider
        assign root_class = root_class | append: ' sp-editorial-differentiation--show-cta-divider'
      endif
    -%}
    <div
      class="{{ root_class }}"
      {% if section.settings.heading != blank %}
        aria-label="{{ section.settings.heading | strip_html | escape }}"
      {% else %}
        aria-label="Editorial differentiation"
      {% endif %}
    >
      {%- if section.settings.show_top_divider -%}
        <div class="sp-editorial-differentiation__chapter-divider" aria-hidden="true"></div>
      {%- endif -%}

      <div class="sp-editorial-differentiation__composition sp-editorial-chapter__lead{% render 'sp-motion-class', type: 'stagger' %}" data-sp-stagger>
        <div class="sp-editorial-differentiation__media sp-editorial-chapter__media{% render 'sp-motion-class', type: 'stagger-item' %}">
          {%- if section.settings.image != blank -%}
            <div class="sp-editorial-differentiation__media-frame sp-editorial-media--cinematic">
              {{
                section.settings.image
                | image_url: width: 2200
                | image_tag:
                  widths: '550, 750, 1100, 1500, 1800, 2200',
                  sizes: '(min-width: 990px) calc((100vw - 8rem) / 2), 100vw',
                  alt: image_alt,
                  loading: 'lazy',
                  class: 'sp-image sp-editorial-differentiation__media-image'
              }}
            </div>
          {%- else -%}
            <div class="sp-editorial-differentiation__media-frame sp-editorial-differentiation__media-frame--placeholder">
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>

        <div class="sp-editorial-differentiation__story{% render 'sp-motion-class', type: 'stagger-item' %}">
          <div class="sp-editorial-differentiation__story-copy">
            {%- if section.settings.eyebrow != blank -%}
              <p class="sp-editorial-differentiation__eyebrow sp-editorial-type--caption caption-with-letter-spacing">
                {{ section.settings.eyebrow | escape }}
              </p>
            {%- endif -%}

            {%- if section.settings.heading != blank -%}
              <h2 class="sp-editorial-differentiation__heading sp-editorial-type--chapter{% render 'sp-motion-class', type: 'fade-up' %}">
                {{ section.settings.heading }}
              </h2>
            {%- endif -%}

            {%- if section.settings.body != blank -%}
              <div class="sp-editorial-differentiation__body rte">
                {{ section.settings.body }}
              </div>
            {%- endif -%}
          </div>

          {%- if section.blocks.size > 0 -%}
            <ol class="sp-editorial-differentiation__proof-list{% render 'sp-motion-class', type: 'stagger' %}" data-sp-stagger>
              {%- for block in section.blocks -%}
                {%- if block.settings.title != blank or block.settings.text != blank -%}
                  <li
                    class="sp-editorial-differentiation__proof-item{% render 'sp-motion-class', type: 'stagger-item' %}"
                    {{ block.shopify_attributes }}
                  >
                    {%- if section.settings.show_proof_numbers -%}
                      <span class="sp-editorial-differentiation__proof-index" aria-hidden="true"></span>
                    {%- endif -%}
                    <div class="sp-editorial-differentiation__proof-content">
                      {%- if block.settings.title != blank -%}
                        <h3 class="sp-editorial-differentiation__proof-title">{{ block.settings.title | escape }}</h3>
                      {%- endif -%}
                      {%- if block.settings.text != blank -%}
                        <p class="sp-editorial-differentiation__proof-text">{{ block.settings.text | escape }}</p>
                      {%- endif -%}
                    </div>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ol>
          {%- endif -%}

          {%- if show_cta or section.settings.trust_text != blank -%}
            <div class="sp-editorial-differentiation__cta-shell{% render 'sp-motion-class', type: 'fade-up' %}">
              {%- if section.settings.show_cta_divider -%}
                <div class="sp-editorial-differentiation__cta-divider" aria-hidden="true"></div>
              {%- endif -%}
              <div class="sp-editorial-differentiation__footer">
                {%- if show_cta -%}
                  <a href="{{ section.settings.button_link }}" class="sp-editorial-differentiation__button sp-editorial-cta sp-editorial-cta--quiet-link{% render 'sp-motion-class', type: 'hover-button' %}">
                    <span>{{ section.settings.button_label | escape }}</span>
                    <span class="sp-editorial-cta__arrow" aria-hidden="true">→</span>
                  </a>
                {%- endif -%}

                {%- if section.settings.trust_text != blank -%}
                  {%- render 'sp-cta-trust-row',
                    trust_text: section.settings.trust_text,
                    wrapper_class: 'sp-editorial-differentiation__trust-row'
                  -%}
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}
{% render 'sp-section-hierarchy-close' %}

{% schema %}
{
  "name": "SP Why Choose",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "presentation",
      "label": "Presentation",
      "default": "split_proof",
      "options": [
        { "value": "split_proof", "label": "Split image + proof" },
        { "value": "philosophy_manifesto", "label": "Philosophy manifesto" }
      ],
      "info": "Philosophy manifesto is designed for formulation philosophy chapters — annotated desktop and mobile editorial compositions."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Editorial image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "default": "Why customers choose us",
      "label": "Eyebrow"
    },
    {
      "type": "richtext",
      "id": "heading",
      "default": "<p>Built for consistency, not quick fixes.</p>",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "body",
      "default": "<p>Designed around the habits people actually keep: simple dosing, clean sourcing, purposeful ingredients, and quality standards you can trust.</p>",
      "label": "Body"
    },
    {
      "type": "text",
      "id": "governing_question",
      "label": "Governing question",
      "info": "Philosophy manifesto presentation only."
    },
    {
      "type": "text",
      "id": "refusals_label",
      "label": "Refusals label",
      "default": "The refusals we live by",
      "info": "Philosophy manifesto presentation only."
    },
    {
      "type": "textarea",
      "id": "refusals_intro",
      "label": "Refusals intro statement",
      "info": "Philosophy manifesto presentation only."
    },
    {
      "type": "text",
      "id": "closing_eyebrow",
      "label": "Closing eyebrow",
      "default": "Our standard of enough",
      "info": "Philosophy manifesto presentation only."
    },
    {
      "type": "richtext",
      "id": "closing_headline",
      "label": "Closing headline",
      "info": "Philosophy manifesto presentation only."
    },
    {
      "type": "text",
      "id": "closing_emphasis",
      "label": "Closing emphasis line",
      "info": "Philosophy manifesto presentation only."
    },
    {
      "type": "richtext",
      "id": "closing_body",
      "label": "Closing supporting copy",
      "info": "Philosophy manifesto presentation only."
    },
    {
      "type": "text",
      "id": "hero_anchor_label",
      "label": "Hero anchor link label",
      "default": "Our standard of enough",
      "info": "Philosophy manifesto presentation only. Mobile composition."
    },
    {
      "type": "url",
      "id": "hero_anchor_link",
      "label": "Hero anchor link",
      "info": "Philosophy manifesto presentation only. Defaults to closing band anchor."
    },
    {
      "type": "text",
      "id": "next_chapter_label",
      "label": "Next chapter label",
      "default": "Next: Scientific confidence",
      "info": "Philosophy manifesto presentation only."
    },
    {
      "type": "url",
      "id": "next_chapter_link",
      "label": "Next chapter link",
      "info": "Philosophy manifesto presentation only. Falls back to button link when blank."
    },
    {
      "type": "text",
      "id": "philosophy_closing_line",
      "label": "Philosophy closing line",
      "info": "Legacy fallback for closing emphasis. Philosophy manifesto presentation only."
    },
    {
      "type": "checkbox",
      "id": "show_philosophy_image",
      "label": "Show visual interruption image",
      "default": true,
      "info": "Philosophy manifesto presentation only."
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "Shop now",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "trust_text",
      "default": "30-day guarantee · Secure checkout",
      "label": "Trust line",
      "info": "Split image + proof presentation only."
    },
    {
      "type": "header",
      "content": "Chapter layout"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Desktop image position",
      "default": "right",
      "info": "Split image + proof presentation only.",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "Top spacing",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "Bottom spacing",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_top_divider",
      "label": "Show top chapter divider",
      "default": false
    },
    {
      "type": "select",
      "id": "background_tone",
      "label": "Background tone",
      "default": "soft",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "soft", "label": "Soft" },
        { "value": "contrast", "label": "Contrast" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_proof_numbers",
      "label": "Show proof point numbers",
      "default": true,
      "info": "Split image + proof presentation only."
    },
    {
      "type": "checkbox",
      "id": "show_cta_divider",
      "label": "Show divider above CTA",
      "default": true
    },
    {
      "type": "header",
      "content": "Visual hierarchy"
    },
    {
      "type": "select",
      "id": "sp_surface_style",
      "label": "Surface style",
      "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "alternate", "label": "Alternate" },
        { "value": "inverse", "label": "Inverse" },
        { "value": "accent", "label": "Accent" },
        { "value": "transparent", "label": "Transparent" }
      ]
    },
    {
      "type": "select",
      "id": "sp_width_mode",
      "label": "Width mode",
      "default": "wide",
      "options": [
        { "value": "contained", "label": "Contained" },
        { "value": "wide", "label": "Wide" },
        { "value": "full", "label": "Full width" },
        { "value": "bleed", "label": "Bleed" }
      ]
    },
    {
      "type": "select",
      "id": "sp_section_emphasis",
      "label": "Section emphasis",
      "default": "normal",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "elevated", "label": "Elevated" },
        { "value": "feature", "label": "Feature" }
      ]
    },
    {
      "type": "select",
      "id": "sp_divider_style",
      "label": "Divider",
