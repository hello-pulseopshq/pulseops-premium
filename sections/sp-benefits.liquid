{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .sp-benefits {
    --sp-benefits-gap-sm: 1.2rem;
    --sp-benefits-gap-md: 1.6rem;
    --sp-benefits-gap-lg: 2.4rem;
    --sp-benefits-radius: 1.6rem;
    --sp-benefits-card-padding: 2rem;
  }

  .sp-benefits__header {
    margin-bottom: var(--sp-benefits-gap-lg);
    max-width: 72rem;
  }

  .sp-benefits__header--center {
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .sp-benefits__header--center .sp-benefits__subheading {
    margin-left: auto;
    margin-right: auto;
  }

  .sp-benefits__heading {
    margin: 0;
  }

  .sp-benefits__subheading {
    margin-top: var(--sp-benefits-gap-sm);
  }

  .sp-benefits__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-benefits-gap-md);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .sp-benefits__item {
    height: 100%;
  }

  .sp-benefits__card {
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--sp-benefits-gap-sm);
    padding: var(--sp-benefits-card-padding);
    border-radius: var(--sp-benefits-radius);
    background: rgba(var(--color-foreground), 0.04);
  }

  .sp-benefits__card--outlined {
    border: 0.1rem solid rgba(var(--color-foreground), 0.2);
    background: transparent;
  }

  .sp-benefits__card--elevated {
    background: rgb(var(--color-background));
    box-shadow: 0 0.6rem 2rem rgba(0, 0, 0, 0.08);
  }

  .sp-benefits__icon {
    width: 2.2rem;
    height: 2.2rem;
    color: rgb(var(--color-foreground));
    flex-shrink: 0;
  }

  .sp-benefits__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .sp-benefits__title {
    margin: 0 0 0.4rem;
  }

  .sp-benefits__description {
    margin: 0;
  }

  .sp-benefits__list--swipe {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(84%, 1fr);
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 0.2rem;
  }

  .sp-benefits__list--swipe .sp-benefits__item {
    scroll-snap-align: start;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .sp-benefits__list--2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .sp-benefits__list--3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .sp-benefits__list--4 {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .sp-benefits__list--swipe {
      grid-auto-flow: row;
      grid-auto-columns: initial;
      overflow-x: visible;
      scroll-snap-type: none;
      padding-bottom: 0;
    }
  }
{%- endstyle -%}

{% render 'sp-section-hierarchy-open', section: section %}
    <div class="sp-benefits" aria-label="{{ section.settings.heading | strip_html | default: 'Benefits' | escape }}">
      {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
        <header class="sp-benefits__header sp-benefits__header--{{ section.settings.content_alignment }}">
          {%- if section.settings.heading != blank -%}
            <h2 class="sp-benefits__heading inline-richtext h1{% render 'sp-motion-class', type: 'fade-up' %}">
              {{ section.settings.heading }}
            </h2>
          {%- endif -%}
          {%- if section.settings.subheading != blank -%}
            <div class="sp-benefits__subheading rte{% render 'sp-motion-class', type: 'fade-up' %}">
              {{ section.settings.subheading }}
            </div>
          {%- endif -%}
        </header>
      {%- endif -%}

      <ul
        class="sp-benefits__list sp-benefits__list--{{ section.settings.desktop_columns }}{% if section.settings.mobile_layout == 'swipe' %} sp-benefits__list--swipe{% endif %}{% render 'sp-motion-class', type: 'stagger' %}"
        data-sp-stagger
        role="list"
      >
        {%- for block in section.blocks -%}
          {%- if block.settings.title != blank or block.settings.description != blank -%}
          <li class="sp-benefits__item{% render 'sp-motion-class', type: 'stagger-item' %}" {{ block.shopify_attributes }}>
            <article class="sp-benefits__card sp-benefits__card--{{ section.settings.card_style }}{% render 'sp-motion-class', type: 'hover-card-subtle' %}">
              <span class="sp-benefits__icon" aria-hidden="true">
                {%- case block.settings.icon -%}
                  {%- when 'star' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                      <path d="m12 3.5 2.6 5.2 5.7.8-4.1 4 1 5.7L12 16.5 6.8 19.2l1-5.7-4.1-4 5.7-.8z"></path>
                    </svg>
                  {%- when 'shield' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                      <path d="M12 2.5 4.5 5.5v6.2c0 4.5 2.8 8.6 7.5 9.8 4.7-1.2 7.5-5.3 7.5-9.8V5.5z"></path>
                      <path d="m8.8 12.1 2.2 2.3 4.3-4.4"></path>
                    </svg>
                  {%- when 'truck' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                      <path d="M1.5 4.5h12v9h-12z"></path>
                      <path d="M13.5 8.5h4l3 3v2h-7z"></path>
                      <circle cx="6" cy="16.5" r="2"></circle>
                      <circle cx="17.5" cy="16.5" r="2"></circle>
                    </svg>
                  {%- when 'leaf' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                      <path d="M20 4.5C11 4.5 5 9.4 5 15.8c0 2.4 1.4 4.7 3.8 5.7 5.5 2.2 11.7-2.1 11.7-9.3 0-2.2-.3-5-0.5-7.7z"></path>
                      <path d="M8 16.5c2.7-.2 5.1-1.7 7.3-4.3"></path>
                    </svg>
                  {%- when 'heart' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                      <path d="M12 20.5 4.6 13.8a4.8 4.8 0 0 1 0-6.8 4.9 4.9 0 0 1 7 0L12 8l.4-1a4.9 4.9 0 0 1 7 0 4.8 4.8 0 0 1 0 6.8z"></path>
                    </svg>
                  {%- when 'lightning' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                      <path d="M13.5 2.5 5 13h5l-1.5 8.5L19 11h-5z"></path>
                    </svg>
                  {%- else -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                      <path d="m5.5 12 4 4 9-9"></path>
                    </svg>
                {%- endcase -%}
              </span>

              {%- if block.settings.title != blank -%}
                <h3 class="sp-benefits__title h4">{{ block.settings.title }}</h3>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <div class="sp-benefits__description rte">
                  {{ block.settings.description }}
                </div>
              {%- endif -%}
            </article>
          </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
{% render 'sp-section-hierarchy-close' %}

