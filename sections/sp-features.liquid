{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .sp-features {
    --sp-features-gap-sm: 1.2rem;
    --sp-features-gap-md: 2rem;
    --sp-features-gap-lg: 3.2rem;
    --sp-features-gap-xl: 6rem;
  }

  .sp-features__header {
    margin-bottom: var(--sp-features-gap-xl);
    max-width: 72rem;
  }

  .sp-features__header--center {
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .sp-features__heading {
    margin: 0;
  }

  .sp-features__subheading {
    margin-top: var(--sp-features-gap-sm);
  }

  .sp-features__list {
    display: flex;
    flex-direction: column;
    gap: 6rem;
  }

  .sp-features__feature {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  .sp-features__media {
    width: 100%;
  }

  .sp-features__image-wrapper {
    width: 100%;
  }

  .sp-features__content {
    max-width: 52rem;
  }

  .sp-features__title {
    margin: 0 0 1rem;
  }

  .sp-features__description {
    margin-bottom: 2rem;
  }

  .sp-features__bullets {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sp-features__bullet {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .sp-features__check {
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    margin-top: 0.2rem;
  }

  .sp-features__check svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .sp-features__button {
    margin-top: 2.4rem;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .sp-features__feature {
      grid-template-columns: 1fr 1fr;
      gap: var(--sp-features-gap-xl);
    }

    .sp-features__feature--reverse .sp-features__media {
      order: 2;
    }

    .sp-features__feature--reverse .sp-features__content {
      order: 1;
    }
  }
{%- endstyle -%}

{% render 'sp-section-hierarchy-open', section: section %}
    <div
      class="sp-features"
      aria-label="{{ section.settings.heading | strip_html | default: 'Features' | escape }}"
    >
      {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
        <header class="sp-features__header sp-features__header--{{ section.settings.content_alignment }}">
          {%- if section.settings.heading != blank -%}
            <h2 class="sp-features__heading inline-richtext h1{% render 'sp-motion-class', type: 'fade-up' %}">
              {{ section.settings.heading }}
            </h2>
          {%- endif -%}

          {%- if section.settings.subheading != blank -%}
            <div class="sp-features__subheading rte{% render 'sp-motion-class', type: 'fade-up' %}">
              {{ section.settings.subheading }}
            </div>
          {%- endif -%}
        </header>
      {%- endif -%}

      <div class="sp-features__list{% render 'sp-motion-class', type: 'stagger' %}" data-sp-stagger>
        {%- for block in section.blocks -%}
          {%- if block.settings.title != blank or block.settings.description != blank or block.settings.image != blank or block.settings.button_label != blank or block.settings.bullet_1 != blank or block.settings.bullet_2 != blank or block.settings.bullet_3 != blank -%}
          {%- assign is_even = forloop.index | modulo: 2 -%}

          <article
            class="sp-features__feature{% if is_even == 0 %} sp-features__feature--reverse{% endif %}{% render 'sp-motion-class', type: 'stagger-item' %}"
            {{ block.shopify_attributes }}
          >
            <div class="sp-features__media{% render 'sp-motion-class', type: 'fade-up' %}">
              {%- capture features_frame_class -%}sp-features__image-wrapper{% render 'sp-motion-class', type: 'hover-image' %}{%- endcapture -%}
              {%- render 'sp-image',
                image: block.settings.image,
                ratio: section.settings.image_ratio,
                frame_class: features_frame_class,
                alt: block.settings.image.alt | default: block.settings.title | strip_html | escape,
                widths: '400, 600, 800, 1200, 1600',
                sizes: '(min-width: 990px) 50vw, 100vw',
                loading: 'lazy'
              -%}
            </div>

            <div class="sp-features__content">
              {%- if block.settings.title != blank -%}
                <h3 class="sp-features__title h2">
                  {{ block.settings.title }}
                </h3>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <div class="sp-features__description rte">
                  {{ block.settings.description }}
                </div>
              {%- endif -%}

              <ul class="sp-features__bullets" role="list">
                {%- for i in (1..3) -%}
                  {%- assign bullet_key = 'bullet_' | append: i -%}
                  {%- assign bullet = block.settings[bullet_key] -%}

                  {%- if bullet != blank -%}
                    <li class="sp-features__bullet">
                      <span class="sp-features__check" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M5 13l4 4L19 7"></path>
                        </svg>
                      </span>
                      <span>{{ bullet }}</span>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>

              {%- if block.settings.button_label != blank and block.settings.button_link != blank -%}
                <div class="sp-features__button">
                  <a
                    href="{{ block.settings.button_link }}"
                    class="button button--secondary{% render 'sp-motion-class', type: 'hover-button' %}"
                  >
                    {{ block.settings.button_label }}
                  </a>
                </div>
              {%- endif -%}
            </div>
          </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
{% render 'sp-section-hierarchy-close' %}

{% schema %}
