{{ 'sp-quality-standards.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign top_extra = 0
  case section.settings.top_spacing
    when 'small'
      assign top_extra = 12
    when 'medium'
      assign top_extra = 28
    when 'large'
      assign top_extra = 48
  endcase

  assign bottom_extra = 0
  case section.settings.bottom_spacing
    when 'small'
      assign bottom_extra = 12
    when 'medium'
      assign bottom_extra = 28
    when 'large'
      assign bottom_extra = 48
  endcase

  assign pad_top = section.settings.padding_top | plus: top_extra
  assign pad_bottom = section.settings.padding_bottom | plus: bottom_extra

  assign presentation = section.settings.presentation | default: 'split_editorial'
  assign shell_class = 'sp-quality-standards-shell sp-quality-standards-shell--tone-' | append: section.settings.background_tone

  assign image_alt = section.settings.image_alt | strip
  if image_alt == blank and section.settings.image != blank
    assign image_alt = section.settings.image.alt | escape
  endif
  if image_alt == blank
    assign image_alt = section.settings.heading | strip_html | escape
  endif

  assign show_cta = false
  if section.settings.button_label != blank and section.settings.button_link != blank
    assign show_cta = true
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ pad_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ pad_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ pad_top }}px;
      padding-bottom: {{ pad_bottom }}px;
    }
  }
{%- endstyle -%}

{% render 'sp-section-hierarchy-open', section: section, anchor_id: 'sp-quality', extra_class: shell_class %}
  {%- if presentation == 'scientific_confidence' -%}
    {%- liquid
      assign scientific_root_class = 'sp-quality-standards sp-composition sp-composition--evidence-panel sp-quality-standards--scientific-confidence sp-editorial-chapter sp-editorial-chapter--spacing-standard sp-editorial-chapter--handoff-in sp-editorial-chapter--handoff-out'
      assign subheadline_stripped = section.settings.subheadline | strip
      assign ledger_label_stripped = section.settings.ledger_label | strip
      assign refusals_label_stripped = section.settings.refusals_label | strip
      assign closure_tagline_stripped = section.settings.closure_tagline | strip
      assign ledger_label_id = section.id | append: '-ledger-label'
      assign refusals_label_id = section.id | append: '-refusals-label'
    -%}
    <div
      class="{{ scientific_root_class }}"
      {% if section.settings.heading != blank %}
        aria-label="{{ section.settings.heading | strip_html | escape }}"
      {% else %}
        aria-label="Scientific confidence"
      {% endif %}
    >
      {%- if section.settings.show_top_divider -%}
        <div class="sp-quality-standards__chapter-divider" aria-hidden="true"></div>
      {%- endif -%}

      <div class="sp-quality-standards__dossier-hero{% render 'sp-motion-class', type: 'fade-in-quiet' %}">
        <header class="sp-quality-standards__dossier-intro">
          {%- if section.settings.eyebrow != blank -%}
            <p class="sp-quality-standards__dossier-label caption-with-letter-spacing">
              {{ section.settings.eyebrow | escape }}
            </p>
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            <h2 class="sp-quality-standards__dossier-headline">
              {{ section.settings.heading }}
            </h2>
          {%- endif -%}

          {%- if subheadline_stripped != blank -%}
            <p class="sp-quality-standards__dossier-subheadline">
              {{ subheadline_stripped | escape }}
            </p>
          {%- endif -%}

          {%- if section.settings.body != blank -%}
            <div class="sp-quality-standards__dossier-intro-body rte">
              {{ section.settings.body }}
            </div>
          {%- endif -%}

          {%- if section.settings.show_metadata -%}
            <dl class="sp-quality-standards__dossier-metadata">
              {%- if section.settings.metadata_doc_label != blank or section.settings.metadata_doc_value != blank -%}
                <div class="sp-quality-standards__dossier-metadata-item">
                  {%- if section.settings.metadata_doc_label != blank -%}
                    <dt class="sp-quality-standards__dossier-metadata-label">
                      {{ section.settings.metadata_doc_label | escape }}
                    </dt>
                  {%- endif -%}
                  {%- if section.settings.metadata_doc_value != blank -%}
                    <dd class="sp-quality-standards__dossier-metadata-value">
                      {{ section.settings.metadata_doc_value | escape }}
                    </dd>
                  {%- endif -%}
                </div>
              {%- endif -%}
              {%- if section.settings.metadata_updated_label != blank or section.settings.metadata_updated_value != blank -%}
                <div class="sp-quality-standards__dossier-metadata-item">
                  {%- if section.settings.metadata_updated_label != blank -%}
                    <dt class="sp-quality-standards__dossier-metadata-label">
                      {{ section.settings.metadata_updated_label | escape }}
                    </dt>
                  {%- endif -%}
                  {%- if section.settings.metadata_updated_value != blank -%}
                    <dd class="sp-quality-standards__dossier-metadata-value">
                      {{ section.settings.metadata_updated_value | escape }}
                    </dd>
                  {%- endif -%}
                </div>
              {%- endif -%}
              {%- if section.settings.metadata_standards_label != blank or section.settings.metadata_standards_value != blank -%}
                <div class="sp-quality-standards__dossier-metadata-item">
                  {%- if section.settings.metadata_standards_label != blank -%}
                    <dt class="sp-quality-standards__dossier-metadata-label">
                      {{ section.settings.metadata_standards_label | escape }}
                    </dt>
                  {%- endif -%}
                  {%- if section.settings.metadata_standards_value != blank -%}
                    <dd class="sp-quality-standards__dossier-metadata-value">
                      {{ section.settings.metadata_standards_value | escape }}
                    </dd>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </dl>
          {%- endif -%}
        </header>

        {%- if section.settings.image != blank -%}
          <figure class="sp-quality-standards__dossier-media">
            <div class="sp-quality-standards__dossier-media-frame">
              {{
                section.settings.image
                | image_url: width: 2400
                | image_tag:
                  widths: '550, 750, 1100, 1500, 1800, 2200, 2400',
                  sizes: '(min-width: 990px) 52vw, 100vw',
                  alt: image_alt,
                  loading: 'lazy',
                  class: 'sp-image sp-quality-standards__dossier-media-image'
              }}
            </div>
          </figure>
        {%- endif -%}
      </div>

      {%- assign ledger_index = 0 -%}
      {%- assign has_ledger = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'evidence_ledger' -%}
          {%- assign has_ledger = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_ledger -%}
        <section
          class="sp-quality-standards__ledger{% render 'sp-motion-class', type: 'fade-in-quiet' %}"
          {% if ledger_label_stripped != blank %}
            aria-labelledby="{{ ledger_label_id }}"
          {% else %}
            aria-label="Evidence ledger"
          {% endif %}
        >
          {%- if ledger_label_stripped != blank -%}
            <p id="{{ ledger_label_id }}" class="sp-quality-standards__ledger-label caption-with-letter-spacing">
              {{ ledger_label_stripped | escape }}
            </p>
          {%- endif -%}

          <ol class="sp-quality-standards__ledger-list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'evidence_ledger' -%}
                {%- liquid
                  assign ledger_index = ledger_index | plus: 1
                  assign ledger_title_stripped = block.settings.title | strip
                  assign ledger_body_stripped = block.settings.description | strip_html | strip
                -%}
                {%- if ledger_title_stripped != blank or ledger_body_stripped != blank -%}
                  <li
                    class="sp-quality-standards__ledger-item"
                    {{ block.shopify_attributes }}
                  >
                    <span class="sp-quality-standards__ledger-index" aria-hidden="true">
                      {%- if ledger_index < 10 -%}0{%- endif -%}{{ ledger_index }}
                    </span>
                    <div class="sp-quality-standards__ledger-copy">
                      {%- if ledger_title_stripped != blank -%}
                        <h3 class="sp-quality-standards__ledger-title">
                          {{ ledger_title_stripped | escape }}
                        </h3>
                      {%- endif -%}
                      {%- if ledger_body_stripped != blank -%}
                        <div class="sp-quality-standards__ledger-body rte">
                          {{ block.settings.description }}
                        </div>
                      {%- endif -%}
                    </div>
                  </li>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </ol>
        </section>
      {%- endif -%}

      {%- assign has_refusals = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'refusal_statement' and block.settings.statement != blank -%}
          {%- assign has_refusals = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if has_refusals -%}
        <section
          class="sp-quality-standards__refusals{% render 'sp-motion-class', type: 'fade-in-quiet' %}"
          {% if refusals_label_stripped != blank %}
            aria-labelledby="{{ refusals_label_id }}"
          {% else %}
            aria-label="What we refuse"
          {% endif %}
        >
          {%- if refusals_label_stripped != blank -%}
            <p id="{{ refusals_label_id }}" class="sp-quality-standards__refusals-label caption-with-letter-spacing">
              {{ refusals_label_stripped | escape }}
            </p>
          {%- endif -%}

          <div class="sp-quality-standards__refusals-manifesto" role="list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'refusal_statement' -%}
                {%- assign refusal_stripped = block.settings.statement | strip -%}
                {%- if refusal_stripped != blank -%}
                  <p class="sp-quality-standards__refusals-item" role="listitem" {{ block.shopify_attributes }}>
                    {{ refusal_stripped | escape }}
                  </p>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        </section>
      {%- endif -%}

      {%- if section.settings.show_closure and section.settings.closure_heading != blank -%}
        <footer class="sp-quality-standards__dossier-closure{% render 'sp-motion-class', type: 'fade-in-quiet' %}">
          {%- if section.settings.show_closure_shield -%}
            <span class="sp-quality-standards__dossier-shield" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2.5 4.5 5.5v6.2c0 4.5 2.8 8.6 7.5 9.8 4.7-1.2 7.5-5.3 7.5-9.8V5.5z"></path>
              </svg>
            </span>
          {%- endif -%}

          <div class="sp-quality-standards__dossier-closure-statement rte">
            {{ section.settings.closure_heading }}
          </div>

          {%- if closure_tagline_stripped != blank -%}
            <p class="sp-quality-standards__dossier-tagline">
              {{ closure_tagline_stripped | escape }}
            </p>
          {%- endif -%}
        </footer>
      {%- endif -%}
    </div>
  {%- else -%}
    {%- liquid
      assign root_class = 'sp-quality-standards'
      assign root_class = root_class | append: ' sp-quality-standards--top-spacing-' | append: section.settings.top_spacing
      assign root_class = root_class | append: ' sp-quality-standards--bottom-spacing-' | append: section.settings.bottom_spacing
    -%}
    <div
      class="{{ root_class }}"
      {% if section.settings.heading != blank %}
        aria-label="{{ section.settings.heading | strip_html | escape }}"
      {% else %}
        aria-label="Quality standards"
      {% endif %}
    >
      {%- if section.settings.show_top_divider -%}
        <div class="sp-quality-standards__chapter-divider" aria-hidden="true"></div>
      {%- endif -%}

      <div class="sp-quality-standards__composition{% render 'sp-motion-class', type: 'stagger' %}" data-sp-stagger>
        <div class="sp-quality-standards__story">
          <header class="sp-quality-standards__story-copy{% render 'sp-motion-class', type: 'stagger-item' %}">
            {%- if section.settings.eyebrow != blank -%}
              <p class="sp-quality-standards__eyebrow caption-with-letter-spacing">
                {{ section.settings.eyebrow | escape }}
              </p>
            {%- endif -%}

            {%- if section.settings.heading != blank -%}
              <h2 class="sp-quality-standards__heading{% render 'sp-motion-class', type: 'fade-up' %}">
                {{ section.settings.heading }}
              </h2>
            {%- endif -%}

            {%- if section.settings.body != blank -%}
              <div class="sp-quality-standards__body rte">
                {{ section.settings.body }}
              </div>
            {%- endif -%}
          </header>

          {%- if section.settings.image != blank -%}
            <div class="sp-quality-standards__media sp-quality-standards__media--mobile{% render 'sp-motion-class', type: 'stagger-item' %}">
              <div class="sp-quality-standards__media-frame">
                {{
                  section.settings.image
                  | image_url: width: 2400
                  | image_tag:
                    widths: '550, 750, 1100, 1500, 1800, 2200, 2400',
                    sizes: '(min-width: 990px) calc((100vw - 8rem) / 2), 100vw',
                    alt: image_alt,
                    loading: 'lazy',
                    class: 'sp-image sp-quality-standards__media-image'
                }}
              </div>
            </div>
          {%- endif -%}

          <div class="sp-quality-standards__story-rest{% render 'sp-motion-class', type: 'stagger-item' %}">
            {%- if section.blocks.size > 0 -%}
              <ul class="sp-quality-standards__proof-list" role="list">
                {%- for block in section.blocks -%}
                  {%- if block.settings.value != blank or block.settings.label != blank -%}
                    <li class="sp-quality-standards__proof-item" {{ block.shopify_attributes }}>
                      <div class="sp-quality-standards__proof-content">
                        {%- if block.settings.value != blank -%}
                          <p class="sp-quality-standards__proof-value">{{ block.settings.value | escape }}</p>
                        {%- endif -%}
                        {%- if block.settings.label != blank -%}
                          <p class="sp-quality-standards__proof-label">{{ block.settings.label | escape }}</p>
                        {%- endif -%}
                        {%- if block.settings.detail != blank -%}
                          <p class="sp-quality-standards__proof-detail">{{ block.settings.detail | escape }}</p>
                        {%- endif -%}
                      </div>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endif -%}

            {%- if section.settings.supporting_text != blank -%}
              <div class="sp-quality-standards__supporting rte{% render 'sp-motion-class', type: 'fade-up' %}">
                {{ section.settings.supporting_text }}
              </div>
            {%- endif -%}

            {%- if show_cta or section.settings.trust_text != blank -%}
              <div class="sp-quality-standards__footer{% render 'sp-motion-class', type: 'fade-up' %}">
                {%- if show_cta -%}
                  <a href="{{ section.settings.button_link }}" class="sp-quality-standards__button button{% render 'sp-motion-class', type: 'hover-button' %}">
                    <span>{{ section.settings.button_label | escape }}</span>
                    <span class="sp-quality-standards__button-arrow" aria-hidden="true">→</span>
                  </a>
                {%- endif -%}

                {%- if section.settings.trust_text != blank -%}
                  {%- render 'sp-cta-trust-row',
                    trust_text: section.settings.trust_text,
                    wrapper_class: 'sp-quality-standards__trust-row'
                  -%}
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>

        {%- if section.settings.image != blank -%}
          <div class="sp-quality-standards__media sp-quality-standards__media--desktop{% render 'sp-motion-class', type: 'stagger-item' %}">
            <div class="sp-quality-standards__media-frame">
              {{
                section.settings.image
                | image_url: width: 2400
                | image_tag:
                  widths: '550, 750, 1100, 1500, 1800, 2200, 2400',
                  sizes: '(min-width: 990px) calc((100vw - 8rem) / 2), 100vw',
                  alt: image_alt,
                  loading: 'lazy',
                  class: 'sp-image sp-quality-standards__media-image'
              }}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
{% render 'sp-section-hierarchy-close' %}

{% schema %}
{
  "name": "SP Quality Standards",
  "tag": "section",
  "class": "section",
  "max_blocks": 10,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "presentation",
      "label": "Presentation",
      "default": "split_editorial",
      "options": [
        { "value": "split_editorial", "label": "Split editorial" },
        { "value": "scientific_confidence", "label": "Scientific confidence" }
      ],
      "info": "Scientific confidence — The Evidence Dossier chapter."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "default": "Lab grade quality",
      "label": "Editorial label",
      "info": "Scientific confidence: chapter label (e.g. Scientific confidence)."
    },
    {
      "type": "richtext",
      "id": "heading",
      "default": "<p>Quality without compromise.</p>",
      "label": "Headline"
    },
    {
      "type": "text",
      "id": "subheadline",
      "label": "Supporting headline",
      "info": "Scientific confidence presentation only."
    },
    {
      "type": "richtext",
      "id": "body",
      "default": "<p>Every batch is produced with strict quality controls, manufacturing discipline, and standards designed to support long-term trust.</p>",
      "label": "Intro paragraph"
    },
    {
      "type": "header",
      "content": "Document metadata"
    },
    {
      "type": "checkbox",
      "id": "show_metadata",
      "label": "Show metadata row",
      "default": true,
      "info": "Scientific confidence presentation only."
    },
    {
      "type": "text",
      "id": "metadata_doc_label",
      "label": "Document number label",
      "default": "Document No.",
      "info": "Scientific confidence presentation only."
    },
    {
      "type": "text",
      "id": "metadata_doc_value",
      "label": "Document number value",
      "default": "SC-01",
      "info": "Scientific confidence presentation only."
    },
    {
      "type": "text",
      "id": "metadata_updated_label",
      "label": "Updated label",
      "default": "Updated",
      "info": "Scientific confidence presentation only."
    },
    {
      "type": "text",
      "id": "metadata_updated_value",
      "label": "Updated value",
      "default": "Quarterly",
      "info": "Scientific confidence presentation only."
    },
    {
      "type": "text",
      "id": "metadata_standards_label",
      "label": "Verification standards label",
      "default": "Verification standards",
      "info": "Scientific confidence presentation only."
    },
    {
      "type": "text",
      "id": "metadata_standards_value",
      "label": "Verification standards value",
      "default": "ISO 17025 · GMP · NSF",
      "info": "Scientific confidence presentation only."
    },
    {
      "type": "header",
      "content": "Documentary photography"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Documentary image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text"
    },
    {
      "type": "header",
      "content": "Evidence ledger"
    },
    {
      "type": "text",
      "id": "ledger_label",
      "label": "Ledger label",
      "default": "Evidence ledger",
      "info": "Scientific confidence presentation only."
    },
    {
      "type": "header",
      "content": "What we refuse"
    },
    {
      "type": "text",
      "id": "refusals_label",
      "label": "Refusals label",
      "default": "What we refuse",
      "info": "Scientific confidence presentation only."
    },
    {
      "type": "richtext",
      "id": "supporting_text",
      "default": "<p>From sourcing to production, every step is designed to maintain consistency, transparency, and quality.</p>",
      "label": "Supporting copy",
      "info": "Split editorial presentation only."
    },
    {
      "type": "header",
      "content": "Chapter closure"
    },
    {
      "type": "checkbox",
      "id": "show_closure",
      "label": "Show closing statement",
      "default": true,
      "info": "Scientific confidence presentation only."
    },
    {
      "type": "richtext",
      "id": "closure_heading",
      "label": "Closing statement",
      "info": "Scientific confidence presentation only."
    },
    {
      "type": "text",
      "id": "closure_tagline",
      "label": "Footer tagline",
      "default": "Documented. Verified. Always.",
      "info": "Scientific confidence presentation only."
    },
    {
      "type": "checkbox",
      "id": "show_closure_shield",
      "label": "Show closure shield icon",
      "default": true,
      "info": "Scientific confidence presentation only."
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "Shop now",
      "label": "Button label",
      "info": "Split editorial presentation only."
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Trust line",
      "info": "Split editorial presentation only."
    },
    {
      "type": "header",
      "content": "Chapter layout"
    },
    {
      "type": "select",
      "id": "top_spacing",
      "label": "Top spacing",
      "default": "medium",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "bottom_spacing",
      "label": "Bottom spacing",
      "default": "large",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_top_divider",
      "label": "Show top chapter divider",
      "default": false
    },
    {
      "type": "select",
      "id": "background_tone",
      "label": "Background tone",
      "default": "soft",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "soft", "label": "Soft" },
        { "value": "contrast", "label": "Contrast" }
      ]
    },
    {
      "type": "header",
      "content": "Visual hierarchy"
    },
    {
      "type": "select",
      "id": "sp_surface_style",
      "label": "Surface style",
      "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "alternate", "label": "Alternate" },
        { "value": "inverse", "label": "Inverse" },
        { "value": "accent", "label": "Accent" },
        { "value": "transparent", "label": "Transparent" }
      ]
    },
    {
      "type": "select",
      "id": "sp_width_mode",
      "label": "Width mode",
      "default": "wide",
      "options": [
        { "value": "contained", "label": "Contained" },
        { "value": "wide", "label": "Wide" },
        { "value": "full", "label": "Full width" },
        { "value": "bleed", "label": "Bleed" }
      ]
    },
    {
      "type": "select",
      "id": "sp_section_emphasis",
      "label": "Section emphasis",
      "default": "normal",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "elevated", "label": "Elevated" },
        { "value": "feature", "label": "Feature" }
      ]
    },
    {
