{{ 'sp-ingredients-spotlight.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign shell_class = 'sp-ingredients-spotlight-shell sp-ingredients-spotlight-shell--tone-' | append: section.settings.background_tone

  assign image_alt = section.settings.image_alt | strip
  if image_alt == blank and section.settings.image != blank
    assign image_alt = section.settings.image.alt | escape
  endif
  if image_alt == blank
    assign image_alt = section.settings.heading | strip_html | escape
  endif

  assign show_cta = false
  if section.settings.button_label != blank and section.settings.button_link != blank
    assign show_cta = true
  endif

  assign heading_stripped = section.settings.heading | strip_html | strip

  assign eyebrow_display = section.settings.eyebrow | strip
  if eyebrow_display contains 'INGREDIENTS'
    assign eyebrow_suffix = eyebrow_display | split: 'INGREDIENTS' | last
    assign eyebrow_display = 'INGREDIENTS' | append: eyebrow_suffix
  endif

  assign formula_strip_link = section.settings.formula_strip_link
  if formula_strip_link == blank
    assign formula_strip_link = section.settings.button_link
  endif

  assign show_formula_strip = false
  if section.settings.formula_strip_text != blank
    assign show_formula_strip = true
  endif

  assign featured_block = blank
  assign featured_index = 0
  assign ingredient_count = 0

  for block in section.blocks
    if block.type == 'ingredient'
      assign name_stripped = block.settings.name | strip
      assign role_stripped = block.settings.role | strip
      assign desc_stripped = block.settings.description | strip_html | strip
      if name_stripped != blank or role_stripped != blank or desc_stripped != blank
        assign ingredient_count = ingredient_count | plus: 1
        if featured_block == blank
          assign featured_block = block
        endif
      endif
    endif
  endfor

  assign trust_count = 0
  for block in section.blocks
    if block.type == 'trust_point' and block.settings.text != blank
      assign trust_count = trust_count | plus: 1
    endif
  endfor

  assign commitment_count = 0
  for block in section.blocks
    if block.type == 'commitment' and block.settings.label != blank
      assign commitment_count = commitment_count | plus: 1
    endif
  endfor
-%}

{% render 'sp-section-hierarchy-open', section: section, anchor_id: 'sp-ingredients', extra_class: shell_class %}
  <div
    class="sp-ingredients-spotlight sp-editorial-chapter sp-editorial-chapter--image-led sp-editorial-chapter--spacing-standard sp-editorial-chapter--handoff-in sp-ingredients-spotlight--editorial"
    aria-label="{{ heading_stripped | default: 'Ingredients spotlight' | escape }}"
  >
    <div class="sp-ingredients-spotlight__hero sp-editorial-chapter__lead">
      <div class="sp-ingredients-spotlight__content{% render 'sp-motion-class', type: 'fade-in-quiet' %}">
        {%- if section.settings.eyebrow != blank -%}
          <p class="sp-ingredients-spotlight__eyebrow sp-editorial-type--caption caption-with-letter-spacing">
            {{ eyebrow_display | escape }}
          </p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="sp-ingredients-spotlight__heading sp-editorial-type--chapter sp-editorial-type--chapter--documentary{% render 'sp-motion-class', type: 'fade-in-quiet' %}">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <div class="sp-ingredients-spotlight__body">
            {{ section.settings.body }}
          </div>
        {%- endif -%}

        {%- if show_cta -%}
          <div class="sp-ingredients-spotlight__actions">
            <a
              href="{{ section.settings.button_link }}"
              class="sp-ingredients-spotlight__button sp-editorial-cta sp-editorial-cta--quiet-link{% render 'sp-motion-class', type: 'hover-button-quiet' %}"
            >
              <span>{{ section.settings.button_label | escape }}</span>
              <span class="sp-editorial-cta__arrow" aria-hidden="true">→</span>
            </a>
          </div>
        {%- endif -%}

        {%- if trust_count > 0 -%}
          <ul class="sp-ingredients-spotlight__trust-list" role="list">
            {%- assign trust_index = 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'trust_point' and block.settings.text != blank -%}
                {%- assign trust_index = trust_index | plus: 1 -%}
                <li class="sp-ingredients-spotlight__trust-item" {{ block.shopify_attributes }}>
                  <span class="sp-ingredients-spotlight__trust-icon sp-ingredients-spotlight__trust-icon--{{ trust_index | modulo: 3 }}" aria-hidden="true">
                    {%- case trust_index | modulo: 3 -%}
                      {%- when 1 -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3c-4 6-7 9-7 12a7 7 0 0 0 14 0c0-3-3-6-7-12Z"></path><path d="M12 11v6"></path></svg>
                      {%- when 2 -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3 4 7v6c0 5 3.5 8 8 8s8-3 8-8V7l-8-4Z"></path></svg>
                      {%- else -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="2.5"></circle><path d="M12 2v3M12 19v3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M2 12h3M19 12h3M4.2 19.8l2.1-2.1M17.7 6.3l2.1-2.1"></path></svg>
                    {%- endcase -%}
                  </span>
                  <span class="sp-ingredients-spotlight__trust-text">{{ block.settings.text | escape }}</span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.microcopy != blank and show_cta == false -%}
          <p class="sp-ingredients-spotlight__microcopy">
            {{ section.settings.microcopy | escape }}
          </p>
        {%- endif -%}
      </div>

      <div class="sp-ingredients-spotlight__media sp-editorial-chapter__media{% render 'sp-motion-class', type: 'fade-in-quiet' %}">
        {%- if section.settings.image != blank -%}
          <div class="sp-ingredients-spotlight__media-frame">
            {{
              section.settings.image
              | image_url: width: 2200
              | image_tag:
                widths: '550, 750, 1100, 1500, 1800, 2200',
                sizes: '(min-width: 990px) 58vw, 100vw',
                alt: image_alt,
                loading: 'lazy',
                class: 'sp-image sp-ingredients-spotlight__media-image'
            }}
          </div>
        {%- else -%}
          <div class="sp-ingredients-spotlight__media-frame sp-ingredients-spotlight__media-frame--placeholder">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- if featured_block != blank -%}
      {%- liquid
        assign featured_name = featured_block.settings.name | strip
        assign featured_role = featured_block.settings.role | strip
        assign featured_desc = featured_block.settings.description
        assign featured_benefit_1 = featured_block.settings.benefit_1 | strip
        assign featured_benefit_2 = featured_block.settings.benefit_2 | strip
        assign featured_benefit_3 = featured_block.settings.benefit_3 | strip
      -%}
      <aside
        class="sp-ingredients-spotlight__featured{% render 'sp-motion-class', type: 'fade-in-quiet' %}"
        aria-label="{{ section.settings.featured_label | default: 'Featured ingredient' | escape }}"
      >
        {%- if section.settings.featured_label != blank -%}
          <p class="sp-ingredients-spotlight__featured-label sp-editorial-type--caption caption-with-letter-spacing">
            {{ section.settings.featured_label | escape }}
          </p>
        {%- endif -%}

        {%- if featured_name != blank -%}
          <h3 class="sp-ingredients-spotlight__featured-name">{{ featured_name | escape }}</h3>
        {%- endif -%}

        {%- if featured_role != blank -%}
          <p class="sp-ingredients-spotlight__featured-role">{{ featured_role | escape }}</p>
        {%- endif -%}

        {%- if featured_desc != blank -%}
          <div class="sp-ingredients-spotlight__featured-description rte">
            {{ featured_desc }}
          </div>
        {%- endif -%}

        {%- if featured_benefit_1 != blank or featured_benefit_2 != blank or featured_benefit_3 != blank -%}
          <ul class="sp-ingredients-spotlight__featured-benefits" role="list">
            {%- if featured_benefit_1 != blank -%}
              <li class="sp-ingredients-spotlight__featured-benefit">{{ featured_benefit_1 | escape }}</li>
            {%- endif -%}
            {%- if featured_benefit_2 != blank -%}
              <li class="sp-ingredients-spotlight__featured-benefit">{{ featured_benefit_2 | escape }}</li>
            {%- endif -%}
            {%- if featured_benefit_3 != blank -%}
              <li class="sp-ingredients-spotlight__featured-benefit">{{ featured_benefit_3 | escape }}</li>
            {%- endif -%}
          </ul>
        {%- endif -%}
      </aside>
    {%- endif -%}

    {%- if ingredient_count > 0 or show_formula_strip or commitment_count > 0 -%}
      <div class="sp-editorial-chapter__body sp-ingredients-spotlight__chapter-body">
    {%- endif -%}

    {%- if ingredient_count > 0 -%}
      <div class="sp-ingredients-spotlight__grid-section{% render 'sp-motion-class', type: 'fade-in-quiet' %}">
        {%- if section.settings.grid_heading != blank -%}
          <div class="sp-ingredients-spotlight__grid-header">
            <h3 class="sp-ingredients-spotlight__grid-heading sp-editorial-type--caption">
              {{ section.settings.grid_heading | escape }}
            </h3>
          </div>
        {%- endif -%}

        <ul class="sp-ingredients-spotlight__grid" role="list">
          {%- assign ingredient_index = 0 -%}
          {%- for block in section.blocks -%}
            {%- unless block.type == 'ingredient' -%}
              {%- continue -%}
            {%- endunless -%}
            {%- liquid
              assign name_stripped = block.settings.name | strip
              assign role_stripped = block.settings.role | strip
              assign desc_stripped = block.settings.description | strip_html | strip
            -%}
            {%- if name_stripped != blank or role_stripped != blank or desc_stripped != blank -%}
              {%- assign ingredient_index = ingredient_index | plus: 1 -%}
              <li
                class="sp-ingredients-spotlight__item{% if featured_block != blank and block.id == featured_block.id %} sp-ingredients-spotlight__item--featured-source{% endif %}"
                {{ block.shopify_attributes }}
              >
                <article class="sp-ingredients-spotlight__item-row">
                  <span
                    class="sp-ingredients-spotlight__item-icon sp-ingredients-spotlight__item-icon--{{ ingredient_index | modulo: 3 }}"
                    aria-hidden="true"
                  >
                    {%- case ingredient_index | modulo: 3 -%}
                      {%- when 1 -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3c-4 6-7 9-7 12a7 7 0 0 0 14 0c0-3-3-6-7-12Z"></path><path d="M12 11v6"></path></svg>
                      {%- when 2 -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3 4 7v6c0 5 3.5 8 8 8s8-3 8-8V7l-8-4Z"></path></svg>
                      {%- else -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="2.5"></circle><path d="M12 2v3M12 19v3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M2 12h3M19 12h3M4.2 19.8l2.1-2.1M17.7 6.3l2.1-2.1"></path></svg>
                    {%- endcase -%}
                  </span>
                  <div class="sp-ingredients-spotlight__item-copy">
                    {%- if name_stripped != blank -%}
                      <h4 class="sp-ingredients-spotlight__item-name">{{ name_stripped | escape }}</h4>
                    {%- endif -%}
                    {%- if desc_stripped != blank -%}
                      <div class="sp-ingredients-spotlight__item-description">
                        {{ block.settings.description }}
                      </div>
                    {%- elsif role_stripped != blank -%}
                      <p class="sp-ingredients-spotlight__item-description sp-ingredients-spotlight__item-description--role">
                        {{ role_stripped | escape }}
                      </p>
                    {%- endif -%}
                  </div>
                </article>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- if show_formula_strip -%}
      <div class="sp-ingredients-spotlight__formula-strip{% render 'sp-motion-class', type: 'fade-in-quiet' %}">
        <p class="sp-ingredients-spotlight__formula-strip-text">
          {{ section.settings.formula_strip_text | escape }}
        </p>
        {%- if section.settings.formula_strip_link_label != blank and formula_strip_link != blank -%}
          <a
            href="{{ formula_strip_link }}"
            class="sp-ingredients-spotlight__formula-strip-link sp-editorial-cta sp-editorial-cta--quiet-link{% render 'sp-motion-class', type: 'hover-button-quiet' %}"
          >
            <span>{{ section.settings.formula_strip_link_label | escape }}</span>
            <span class="sp-editorial-cta__arrow" aria-hidden="true">→</span>
          </a>
        {%- endif -%}
      </div>
    {%- elsif commitment_count > 0 -%}
      <div class="sp-ingredients-spotlight__commitment{% render 'sp-motion-class', type: 'fade-in-quiet' %}">
        {%- if section.settings.commitment_heading != blank -%}
          <h3 class="sp-ingredients-spotlight__commitment-heading">
            {{ section.settings.commitment_heading | escape }}
          </h3>
        {%- endif -%}

        <ul class="sp-ingredients-spotlight__commitment-list" role="list">
          {%- for block in section.blocks -%}
            {%- unless block.type == 'commitment' -%}
              {%- continue -%}
            {%- endunless -%}
            {%- if block.settings.label != blank -%}
              <li class="sp-ingredients-spotlight__commitment-item" {{ block.shopify_attributes }}>
                <span class="sp-ingredients-spotlight__commitment-label">{{ block.settings.label | escape }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {%- if ingredient_count > 0 or show_formula_strip or commitment_count > 0 -%}
      </div>
    {%- endif -%}
  </div>
{% render 'sp-section-hierarchy-close' %}

{% schema %}
{
  "name": "SP Ingredients Spotlight",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "WHAT'S INSIDE DAILY VITALITY"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Purposeful ingredients.<br>Real results.</p>"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>A science-backed formula featuring clinically studied ingredients in effective amounts—working together to support energy, gut health, recovery, and daily vitality.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Ingredient flat-lay image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Daily Vitality ingredient flat lay with capsules and whole-food sources"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "See full formula & amounts"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "microcopy",
      "label": "Microcopy below button",
      "default": "Transparent. No proprietary blends."
    },
    {
      "type": "text",
      "id": "grid_heading",
      "label": "Ingredient grid heading",
      "default": "KEY INGREDIENTS. CLEAR PURPOSE."
    },
    {
      "type": "text",
      "id": "featured_label",
      "label": "Featured ingredient label",
      "default": "Featured ingredient",
      "info": "Mobile featured card only. Uses the first ingredient block."
    },
    {
      "type": "text",
      "id": "formula_strip_text",
      "label": "Formula reassurance text",
      "default": "No fillers. No unnecessary additives. Just pure ingredients for real results."
    },
    {
      "type": "text",
      "id": "formula_strip_link_label",
      "label": "Formula strip link label",
      "default": "View complete formula"
    },
    {
      "type": "url",
      "id": "formula_strip_link",
      "label": "Formula strip link",
      "info": "Falls back to the main button link when blank."
    },
    {
      "type": "text",
      "id": "commitment_heading",
      "label": "Commitment strip heading",
      "default": "Our commitment to you"
    },
    {
      "type": "select",
      "id": "background_tone",
      "label": "Background tone",
      "default": "soft",
      "options": [
        { "value": "soft", "label": "Soft ivory" },
        { "value": "default", "label": "Default" },
        { "value": "contrast", "label": "Contrast" }
      ]
    },
    {
      "type": "header",
      "content": "Visual hierarchy"
    },
    {
      "type": "select",
      "id": "sp_surface_style",
      "label": "Surface style",
      "default": "default",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "alternate", "label": "Alternate" },
        { "value": "inverse", "label": "Inverse" },
        { "value": "accent", "label": "Accent" },
        { "value": "transparent", "label": "Transparent" }
      ]
    },
    {
      "type": "select",
      "id": "sp_width_mode",
      "label": "Width mode",
      "default": "wide",
      "options": [
        { "value": "contained", "label": "Contained" },
        { "value": "wide", "label": "Wide" },
        { "value": "full", "label": "Full width" },
        { "value": "bleed", "label": "Bleed" }
      ]
    },
    {
      "type": "select",
      "id": "sp_section_emphasis",
      "label": "Section emphasis",
      "default": "normal",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "elevated", "label": "Elevated" },
        { "value": "feature", "label": "Feature" }
      ]
    },
    {
      "type": "select",
      "id": "sp_divider_style",
      "label": "Divider",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "line", "label": "Line" },
        { "value": "fade", "label": "Fade" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 88
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 88
    }
  ],
  "blocks": [
    {
      "type": "trust_point",
      "name": "Trust point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Clinically studied ingredients"
        }
      ]
    },
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Ingredient name",
          "default": "Ingredient name"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role line",
          "default": "For daily support"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Ingredient image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Ingredient image alt text"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Short description of this ingredient and its role in the formula.</p>"
        },
        {
          "type": "text",
          "id": "benefit_1",
          "label": "Featured benefit 1",
          "info": "First ingredient block only. Mobile featured card."
        },
        {
          "type": "text",
          "id": "benefit_2",
          "label": "Featured benefit 2"
        },
        {
          "type": "text",
          "id": "benefit_3",
          "label": "Featured benefit 3"
        }
      ]
    },
    {
      "type": "commitment",
      "name": "Commitment item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Third-Party Tested"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SP Ingredients Spotlight",
      "blocks": [
        { "type": "trust_point", "settings": { "text": "Clinically studied ingredients" } },
        { "type": "trust_point", "settings": { "text": "Effective doses, not fillers" } },
        { "type": "trust_point", "settings": { "text": "Third-party tested for purity" } },
        {
          "type": "ingredient",
          "settings": {
            "name": "B-Vitamin Complex",
            "role": "For Daily Energy & Focus",
            "description": "<p>Activated forms of B6, B12, folate and more to support cellular energy and mental clarity.</p>"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Rhodiola Rosea",
            "role": "For Stress Resilience",
            "description": "<p>A clinically studied adaptogen selected to support resilience during daily stress and fatigue.</p>"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Probiotic Blend",
            "role": "For Gut Balance",
            "description": "<p>Clinically studied strains selected to support digestion, nutrient absorption, and regularity.</p>"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Magnesium Glycinate",
            "role": "For Recovery & Relaxation",
            "description": "<p>A highly absorbable form of magnesium selected to support muscle recovery, relaxation, and sleep quality.</p>"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "L-Theanine",
            "role": "For Calm Focus",
            "description": "<p>Supports relaxation without drowsiness and helps maintain calm, sustained attention.</p>"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "BioPerine®",
            "role": "For Better Absorption",
            "description": "<p>Black pepper extract selected to support bioavailability of key nutrients.</p>"
          }
        },
        { "type": "commitment", "settings": { "label": "Clean & Non-GMO" } },
        { "type": "commitment", "settings": { "label": "Third-Party Tested" } },
        { "type": "commitment", "settings": { "label": "Made in GMP Facilities" } },
        { "type": "commitment", "settings": { "label": "No Fillers or Binders" } },
        { "type": "commitment", "settings": { "label": "30-Day Guarantee" } }
      ]
    }
  ]
}
{% endschema %}
