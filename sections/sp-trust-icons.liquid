{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .sp-trust-icons {
    --sp-trust-icons-gap-sm: 1.2rem;
    --sp-trust-icons-gap-md: 1.6rem;
    --sp-trust-icons-gap-lg: 2.4rem;
    --sp-trust-icons-card-padding: 2rem;
    --sp-trust-icons-icon-size: 2.4rem;
  }

  .sp-trust-icons__header {
    margin-bottom: var(--sp-trust-icons-gap-lg);
    max-width: 72rem;
  }

  .sp-trust-icons__header--center {
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .sp-trust-icons__header--center .sp-trust-icons__subheading {
    margin-left: auto;
    margin-right: auto;
  }

  .sp-trust-icons__heading {
    margin: 0;
  }

  .sp-trust-icons__subheading {
    margin-top: var(--sp-trust-icons-gap-sm);
  }

  .sp-trust-icons__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-trust-icons-gap-md);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .sp-trust-icons__item {
    height: 100%;
  }

  .sp-trust-icons__card {
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    padding: var(--sp-trust-icons-card-padding);
    border-radius: var(--media-radius);
  }

  .sp-trust-icons__card--minimal {
    padding: 1.2rem 0;
    background: transparent;
  }

  .sp-trust-icons__card--subtle {
    background: rgba(var(--color-foreground), 0.04);
    border: 0.1rem solid rgba(var(--color-foreground), 0.08);
  }

  .sp-trust-icons__card--bordered {
    background: transparent;
    border: 0.1rem solid rgba(var(--color-foreground), 0.14);
  }

  .sp-trust-icons__list--center .sp-trust-icons__card {
    align-items: center;
    text-align: center;
  }

  .sp-trust-icons__body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 0;
  }

  .sp-trust-icons__icon {
    width: var(--sp-trust-icons-icon-size);
    height: var(--sp-trust-icons-icon-size);
    flex-shrink: 0;
    color: rgb(var(--color-foreground));
  }

  .sp-trust-icons__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .sp-trust-icons__title {
    margin: 0;
    line-height: 1.25;
  }

  .sp-trust-icons__text {
    margin: 0;
    opacity: 0.75;
    line-height: 1.5;
  }

  .sp-trust-icons__text > :first-child {
    margin-top: 0;
  }

  .sp-trust-icons__text > :last-child {
    margin-bottom: 0;
  }

  .sp-trust-icons__list--swipe {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(84%, 1fr);
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 0.2rem;
    scrollbar-width: none;
  }

  .sp-trust-icons__list--swipe::-webkit-scrollbar {
    display: none;
  }

  .sp-trust-icons__list--swipe .sp-trust-icons__item {
    scroll-snap-align: start;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .sp-trust-icons__list--2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .sp-trust-icons__list--3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .sp-trust-icons__list--4 {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .sp-trust-icons__list--inline-desktop .sp-trust-icons__card {
      flex-direction: row;
      align-items: flex-start;
      gap: 1.2rem;
      text-align: left;
    }

    .sp-trust-icons__list--inline-desktop.sp-trust-icons__list--center .sp-trust-icons__card {
      align-items: flex-start;
      text-align: left;
    }

    .sp-trust-icons__list--inline-desktop .sp-trust-icons__icon {
      width: 2rem;
      height: 2rem;
      margin-top: 0.15rem;
    }

    .sp-trust-icons__list--swipe {
      grid-auto-flow: row;
      grid-auto-columns: initial;
      overflow-x: visible;
      scroll-snap-type: none;
      padding-bottom: 0;
    }
  }
{%- endstyle -%}

{% render 'sp-section-hierarchy-open', section: section %}
  <div
    class="sp-trust-icons"
    aria-label="{{ section.settings.heading | strip_html | default: 'Trust icons' | escape }}"
  >
    {%- liquid
      assign heading_stripped = section.settings.heading | strip_html | strip
      assign subheading_stripped = section.settings.subheading | strip_html | strip
    -%}

    {%- if heading_stripped != blank or subheading_stripped != blank -%}
      <header class="sp-trust-icons__header sp-trust-icons__header--{{ section.settings.content_alignment }}">
        {%- if heading_stripped != blank -%}
          <h2 class="sp-trust-icons__heading inline-richtext h2{% render 'sp-motion-class', type: 'fade-up' %}">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
        {%- if subheading_stripped != blank -%}
          <div class="sp-trust-icons__subheading rte{% render 'sp-motion-class', type: 'fade-up' %}">
            {{ section.settings.subheading }}
          </div>
        {%- endif -%}
      </header>
    {%- endif -%}

    <ul
      class="sp-trust-icons__list sp-trust-icons__list--{{ section.settings.desktop_columns }}{% if section.settings.content_alignment == 'center' %} sp-trust-icons__list--center{% endif %}{% if section.settings.desktop_layout == 'inline' %} sp-trust-icons__list--inline-desktop{% endif %}{% if section.settings.mobile_layout == 'swipe' %} sp-trust-icons__list--swipe{% endif %}{% render 'sp-motion-class', type: 'stagger' %}"
      data-sp-stagger
      role="list"
    >
      {%- for block in section.blocks -%}
        {%- liquid
          assign title_stripped = block.settings.heading | strip
          assign text_stripped = block.settings.text | strip_html | strip
        -%}
        {%- if title_stripped != blank or text_stripped != blank -%}
          <li class="sp-trust-icons__item{% render 'sp-motion-class', type: 'stagger-item' %}" {{ block.shopify_attributes }}>
            <article class="sp-trust-icons__card sp-trust-icons__card--{{ section.settings.card_style }}{% render 'sp-motion-class', type: 'hover-card-subtle' %}">
              <span class="sp-trust-icons__icon" aria-hidden="true">
                {%- case block.settings.icon -%}
                  {%- when 'shield' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                      <path d="M12 2.5 4.5 5.5v6.2c0 4.5 2.8 8.6 7.5 9.8 4.7-1.2 7.5-5.3 7.5-9.8V5.5z"></path>
                      <path d="m8.8 12.1 2.2 2.3 4.3-4.4"></path>
                    </svg>
                  {%- when 'truck' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                      <path d="M1.5 4.5h12v9h-12z"></path>
                      <path d="M13.5 8.5h4l3 3v2h-7z"></path>
                      <circle cx="6" cy="16.5" r="2"></circle>
                      <circle cx="17.5" cy="16.5" r="2"></circle>
                    </svg>
                  {%- when 'return' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                      <path d="M4 7.5h11.5a3.5 3.5 0 0 1 0 7H12"></path>
                      <path d="M7.5 4.5 4 7.5l3.5 3"></path>
                    </svg>
                  {%- when 'guarantee' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                      <circle cx="12" cy="12" r="8.5"></circle>
                      <path d="M8.5 12.2 11 14.7 16 9.5"></path>
                    </svg>
                  {%- when 'lock' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                      <rect x="5" y="10" width="14" height="11" rx="2"></rect>
                      <path d="M8 10V7.5a4 4 0 0 1 8 0V10"></path>
                    </svg>
                  {%- when 'support' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                      <path d="M4 14.5a8 8 0 0 1 16 0"></path>
                      <path d="M12 14.5V20"></path>
                      <path d="M8.5 20h7"></path>
                      <path d="M7 10.5a5 5 0 0 1 10 0"></path>
                    </svg>
                  {%- else -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                      <path d="m5.5 12 4 4 9-9"></path>
                    </svg>
                {%- endcase -%}
              </span>

              <div class="sp-trust-icons__body">
              {%- if title_stripped != blank -%}
                <h3 class="sp-trust-icons__title h4">{{ block.settings.heading | escape }}</h3>
              {%- endif -%}

              {%- if text_stripped != blank -%}
                <div class="sp-trust-icons__text rte">
                  {{ block.settings.text }}
                </div>
              {%- endif -%}
              </div>
            </article>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </div>
{% render 'sp-section-hierarchy-close' %}

{% schema %}
{
  "name": "SP Trust Icons",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "Desktop columns",
      "default": "4",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ]
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card style",
      "default": "minimal",
      "options": [
        { "value": "minimal", "label": "Minimal" },
        { "value": "subtle", "label": "Subtle" },
        { "value": "bordered", "label": "Bordered" }
      ]
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "Desktop layout",
      "default": "inline",
      "info": "Inline places the icon beside text — ideal near checkout. Stack matches Benefits-style cards.",
      "options": [
        { "value": "stack", "label": "Stack" },
        { "value": "inline", "label": "Inline" }
      ]
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "default": "stack",
      "options": [
        { "value": "stack", "label": "Stack" },
        { "value": "swipe", "label": "Swipe" }
      ]
    },
    {
      "type": "header",
      "content": "Visual hierarchy"
    },
    {
      "type": "select",
      "id": "sp_surface_style",
      "label": "Surface style",
      "default": "default",
      "info": "Inverse uses the inverse color scheme from Theme settings → SP Visual hierarchy instead of the section Color scheme below.",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "alternate", "label": "Alternate" },
        { "value": "inverse", "label": "Inverse" },
        { "value": "accent", "label": "Accent" },
        { "value": "transparent", "label": "Transparent" }
      ]
    },
    {
      "type": "select",
      "id": "sp_width_mode",
      "label": "Width mode",
      "default": "contained",
      "options": [
        { "value": "contained", "label": "Contained" },
        { "value": "wide", "label": "Wide" },
        { "value": "full", "label": "Full width" },
        { "value": "bleed", "label": "Bleed" }
      ]
    },
    {
      "type": "select",
      "id": "sp_section_emphasis",
      "label": "Section emphasis",
      "default": "normal",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "elevated", "label": "Elevated" },
        { "value": "feature", "label": "Feature" }
      ]
    },
    {
      "type": "select",
      "id": "sp_divider_style",
      "label": "Divider",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "line", "label": "Line" },
        { "value": "gradient", "label": "Gradient" },
        { "value": "fade", "label": "Fade" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "info": "Not applied when Surface style is set to Inverse.",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 28
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "shield",
          "options": [
            { "value": "check", "label": "Checkmark" },
            { "value": "shield", "label": "Secure" },
            { "value": "lock", "label": "Lock" },
            { "value": "truck", "label": "Shipping" },
            { "value": "return", "label": "Returns" },
            { "value": "guarantee", "label": "Guarantee" },
            { "value": "support", "label": "Support" }
          ]
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Secure checkout"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Supporting text",
          "default": "<p>256-bit SSL encryption on every order.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SP Trust Icons",
      "settings": {
        "heading": "Shop with confidence",
        "content_alignment": "center",
        "card_style": "minimal",
        "desktop_layout": "inline"
      },
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "lock",
            "heading": "Secure checkout",
            "text": "<p>256-bit SSL encryption on every order.</p>"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "truck",
            "heading": "Fast shipping",
            "text": "<p>Free delivery on orders over $50.</p>"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "return",
            "heading": "Easy returns",
            "text": "<p>30-day hassle-free return policy.</p>"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "guarantee",
            "heading": "Money-back guarantee",
            "text": "<p>Love it or get a full refund.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
