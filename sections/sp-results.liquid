{{ 'section-sp-results.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% render 'sp-section-hierarchy-open', section: section %}
    <div class="sp-results" data-sp-results>
      {%- liquid
        assign heading_stripped = section.settings.heading | strip_html | strip
        assign subheading_stripped = section.settings.subheading | strip_html | strip
        assign badge_stripped = section.settings.header_badge_text | strip
        assign trust_note_display = section.settings.trust_note_text | strip
        if trust_note_display == blank
          assign trust_note_display = 'Based on aggregated customer feedback and internal testing.'
        endif
        assign show_section_header = false
        if heading_stripped != blank or subheading_stripped != blank
          assign show_section_header = true
        elsif section.settings.show_header_badge and badge_stripped != blank
          assign show_section_header = true
        elsif section.settings.show_trust_note
          assign show_section_header = true
        endif
      -%}

      {%- if show_section_header -%}
        <header class="sp-results__header sp-results__header--{{ section.settings.content_alignment }}">
          {%- if section.settings.show_header_badge and badge_stripped != blank -%}
            <p class="sp-results__proof-badge caption-with-letter-spacing">
              {{ badge_stripped | escape }}
            </p>
          {%- endif -%}

          {%- if heading_stripped != blank -%}
            <h2 class="sp-results__heading inline-richtext h1{% render 'sp-motion-class', type: 'fade-up' %}">
              {{ section.settings.heading }}
            </h2>
          {%- endif -%}

          {%- if subheading_stripped != blank -%}
            <div class="sp-results__subheading rte{% render 'sp-motion-class', type: 'fade-up' %}">
              {{ section.settings.subheading }}
            </div>
          {%- endif -%}

          {%- if section.settings.show_trust_note -%}
            <p class="sp-results__trust-note caption">
              {{ trust_note_display | escape }}
            </p>
          {%- endif -%}
        </header>
      {%- endif -%}

      {%- assign valid_results = 0 -%}
      {%- capture results_list -%}
        {%- for block in section.blocks -%}
          {%- liquid
            assign title_stripped = block.settings.result_title | strip
            assign before_stripped = block.settings.before_value | strip
            assign after_stripped = block.settings.after_value | strip
            assign description_stripped = block.settings.result_description | strip_html | strip
            assign impact_stripped = block.settings.impact_label | strip
            assign customer_name_stripped = block.settings.customer_name | strip
            assign customer_context_stripped = block.settings.customer_context | strip

            assign is_valid_result = false
            if title_stripped != blank or before_stripped != blank or after_stripped != blank or description_stripped != blank
              assign is_valid_result = true
            endif

            assign has_transform = false
            if before_stripped != blank or after_stripped != blank
              assign has_transform = true
            endif

            assign progress_percent = block.settings.progress_percent | plus: 0
            assign show_progress_bar = false
            if has_transform
              if progress_percent < 0
                assign progress_percent = 0
              elsif progress_percent > 100
                assign progress_percent = 100
              endif
              assign show_progress_bar = true
            endif

            assign has_customer_proof = false
            if block.settings.customer_avatar != blank or customer_name_stripped != blank or customer_context_stripped != blank
              assign has_customer_proof = true
            endif

            assign customer_initials = ''
            if customer_name_stripped != blank
              assign name_words = customer_name_stripped | split: ' '
              assign customer_initials = name_words | first | slice: 0, 1
              if name_words.size > 1
                assign last_word = name_words | last
                assign customer_initials = customer_initials | append: last_word | slice: 0, 1
              endif
              assign customer_initials = customer_initials | upcase
            endif

            assign show_customer_avatar = false
            if block.settings.customer_avatar != blank
              assign show_customer_avatar = true
            elsif customer_initials != blank
              assign show_customer_avatar = true
            endif

            assign show_customer_meta = false
            if customer_name_stripped != blank or customer_context_stripped != blank
              assign show_customer_meta = true
            endif

            assign show_verified_badge = false
            if has_customer_proof and block.settings.verified_customer
              assign show_verified_badge = true
            endif

            assign show_proof_footer = false
            if show_customer_avatar or show_customer_meta or show_verified_badge
              assign show_proof_footer = true
            endif

            if customer_name_stripped != blank
              assign avatar_alt = 'Avatar of ' | append: customer_name_stripped
            else
              assign avatar_alt = 'Customer avatar'
            endif

            assign transform_aria_label = 'Before and after comparison'
            if before_stripped != blank and after_stripped != blank
              assign transform_aria_label = 'Before: ' | append: before_stripped | append: ', After: ' | append: after_stripped
            elsif before_stripped != blank
              assign transform_aria_label = 'Before: ' | append: before_stripped
            elsif after_stripped != blank
              assign transform_aria_label = 'After: ' | append: after_stripped
            endif

            assign is_featured = false
            if section.settings.highlight_best_result and block.settings.is_best_result
              assign is_featured = true
            endif
          -%}
          {%- if is_valid_result -%}
            {%- assign valid_results = valid_results | plus: 1 -%}
            <li class="sp-results__item{% render 'sp-motion-class', type: 'stagger-item' %}" {{ block.shopify_attributes }}>
              <article class="sp-results__card{% if is_featured %} sp-results__card--featured{% endif %}{% render 'sp-motion-class', type: 'hover-card-subtle' %}">
                {%- if is_featured -%}
                  <p class="sp-results__badge caption">Best Result</p>
                {%- endif -%}

                <div class="sp-results__card-header{% if title_stripped == blank and impact_stripped == blank %} sp-results__card-header--icon-only{% endif %}">
                  {%- if title_stripped != blank or impact_stripped != blank -%}
                    <div class="sp-results__title-group">
                      {%- if title_stripped != blank -%}
                        <h3 class="sp-results__title h4">
                          {{ title_stripped | escape }}
                        </h3>
                      {%- endif -%}

                      {%- if impact_stripped != blank -%}
                        <p class="sp-results__impact caption">{{ impact_stripped | escape }}</p>
                      {%- endif -%}
                    </div>
                  {%- endif -%}

                  <span class="sp-results__icon" aria-hidden="true">
                      {%- case block.settings.icon -%}
                        {%- when 'chart' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" focusable="false">
                            <path d="M4 19V5"></path>
                            <path d="M4 19h16"></path>
                            <path d="M8 15V9"></path>
                            <path d="M12 15V7"></path>
                            <path d="M16 15v-4"></path>
                          </svg>
                        {%- when 'arrow' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" focusable="false">
                            <path d="M5 12h14"></path>
                            <path d="M13 6l6 6-6 6"></path>
                          </svg>
                        {%- when 'spark' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" focusable="false">
                            <path d="M12 3.5 9.5 12 3 14.5 9.5 12 12 20.5 14.5 12 21 9.5 14.5 12z"></path>
                          </svg>
                        {%- when 'trend' -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" focusable="false">
                            <path d="M4 18h16"></path>
                            <path d="M6 14l4-4 3 3 5-6"></path>
                          </svg>
                        {%- else -%}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true" focusable="false">
                            <circle cx="12" cy="12" r="9"></circle>
                            <path d="M8 12.5 10.5 15 16 9"></path>
                          </svg>
                      {%- endcase -%}
                    </span>
                  </div>

                {%- if has_transform -%}
                  <div class="sp-results__transform" role="group" aria-label="{{ transform_aria_label | escape }}">
                    {%- if before_stripped != blank -%}
                      <div class="sp-results__value sp-results__value--before">
                        <span class="sp-results__value-label caption">Before</span>
                        {{ before_stripped | escape }}
                      </div>
                    {%- else -%}
                      <div class="sp-results__value sp-results__value--before" aria-hidden="true">
                        <span aria-hidden="true">-</span>
                      </div>
                    {%- endif -%}

                    <span class="sp-results__arrow" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                        <path d="M5 12h14"></path>
                        <path d="M13 6l6 6-6 6"></path>
                      </svg>
                    </span>

                    {%- if after_stripped != blank -%}
                      <div class="sp-results__value sp-results__value--after">
                        <span class="sp-results__value-label caption">After</span>
                        {{ after_stripped | escape }}
                      </div>
                    {%- else -%}
                      <div class="sp-results__value sp-results__value--after" aria-hidden="true">
                        <span aria-hidden="true">-</span>
                      </div>
                    {%- endif -%}
                  </div>

                  {%- if show_progress_bar -%}
                    <div
                      class="sp-results__progress"
                      data-sp-results-progress="{{ progress_percent }}"
                      style="--sp-results-progress-target: {{ progress_percent }}%;"
                      role="progressbar"
                      aria-valuemin="0"
                      aria-valuemax="100"
                      aria-valuenow="{{ progress_percent }}"
                      aria-label="Progress: {{ progress_percent }}%"
                    >
                      <span class="sp-results__progress-fill"></span>
                    </div>
                  {%- endif -%}
                {%- endif -%}

                {%- if description_stripped != blank -%}
                  <div class="sp-results__description rte">
                    {{ block.settings.result_description }}
                  </div>
                {%- endif -%}

                {%- if show_proof_footer -%}
                  <footer class="sp-results__proof">
                    {%- if block.settings.customer_avatar != blank -%}
                      <div class="sp-results__avatar sp-media-frame sp-media-frame--circle sp-media-frame--intrinsic">
                        {%- render 'sp-image',
                          image: block.settings.customer_avatar,
                          img_only: true,
                          alt: avatar_alt,
                          widths: '36, 72',
                          sizes: '36px',
                          image_width: 72,
                          loading: 'lazy'
                        -%}
                      </div>
                    {%- elsif customer_initials != blank -%}
                      <div class="sp-results__avatar sp-results__avatar--initials" aria-hidden="true">
                        {{ customer_initials }}
                      </div>
                    {%- endif -%}

                    {%- if show_customer_meta -%}
                      <div class="sp-results__customer">
                        {%- if customer_name_stripped != blank -%}
                          <p class="sp-results__customer-name">
                            {{ customer_name_stripped | escape }}
                          </p>
                        {%- endif -%}
                        {%- if customer_context_stripped != blank -%}
                          <p class="sp-results__customer-context caption">
                            {{ customer_context_stripped | escape }}
                          </p>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                    {%- if show_verified_badge -%}
                      <span class="sp-results__verified caption">Verified customer</span>
                    {%- endif -%}
                  </footer>
                {%- endif -%}
              </article>
            </li>
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}

      {%- if valid_results > 0 -%}
        <ul
          class="sp-results__list sp-results__list--{{ section.settings.desktop_columns }}{% render 'sp-motion-class', type: 'stagger' %}"
          data-sp-stagger
          role="list"
        >
          {{ results_list }}
        </ul>
      {%- elsif request.design_mode -%}
        <div class="sp-results__empty-state">
          Add result blocks to display before and after outcomes.
        </div>
      {%- endif -%}
    </div>
{% render 'sp-section-hierarchy-close' %}

<script src="{{ 'sp-results.js' | asset_url }}" defer="defer"></script>

{% schema %}
