{{ 'sp-faq.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% render 'sp-section-hierarchy-open', section: section %}
    <div class="sp-faq">
      {%- liquid
        assign heading_stripped = section.settings.heading | strip_html | strip
        assign subheading_stripped = section.settings.subheading | strip_html | strip
      -%}

      {%- if heading_stripped != blank or subheading_stripped != blank -%}
        <header class="sp-faq__header sp-faq__header--{{ section.settings.content_alignment }}">
          {%- if heading_stripped != blank -%}
            <h2 class="sp-faq__heading inline-richtext h1">
              {{ section.settings.heading }}
            </h2>
          {%- endif -%}
          {%- if subheading_stripped != blank -%}
            <div class="sp-faq__subheading rte">
              {{ section.settings.subheading }}
            </div>
          {%- endif -%}
        </header>
      {%- endif -%}

      {%- assign valid_items = 0 -%}
      {%- for block in section.blocks -%}
        {%- assign question_stripped = block.settings.question | strip -%}
        {%- if question_stripped != blank -%}
          {%- assign valid_items = valid_items | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if valid_items > 0 -%}
        <ul class="sp-faq__list" data-sp-faq-list>
          {%- assign first_valid_item = true -%}
          {%- for block in section.blocks -%}
            {%- liquid
              assign question_stripped = block.settings.question | strip
              assign answer_stripped = block.settings.answer | strip_html | strip
              assign is_first_open = false
              if section.settings.open_first_item and first_valid_item and question_stripped != blank
                assign is_first_open = true
              endif
            -%}
            {%- if question_stripped != blank -%}
              {%- assign first_valid_item = false -%}
              {%- assign panel_id = 'SpFaq-panel-' | append: section.id | append: '-' | append: block.id -%}
              {%- assign trigger_id = 'SpFaq-trigger-' | append: section.id | append: '-' | append: block.id -%}
              <li
                class="sp-faq__item{% if is_first_open %} is-open{% endif %}"
                {{ block.shopify_attributes }}
              >
                <h3 class="sp-faq__item-heading h4">
                  <button
                    type="button"
                    class="sp-faq__trigger"
                    id="{{ trigger_id }}"
                    aria-expanded="{% if is_first_open %}true{% else %}false{% endif %}"
                    aria-controls="{{ panel_id }}"
                  >
                    <span class="sp-faq__question">{{ block.settings.question | escape }}</span>
                    <span class="sp-faq__icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path class="sp-faq__icon-line--horizontal" d="M5 12h14"></path>
                        <path class="sp-faq__icon-line--vertical" d="M12 5v14"></path>
                      </svg>
                    </span>
                  </button>
                </h3>

                <div
                  id="{{ panel_id }}"
                  class="sp-faq__panel"
                  role="region"
                  aria-labelledby="{{ trigger_id }}"
                  aria-hidden="{% if is_first_open %}false{% else %}true{% endif %}"
                  {% unless is_first_open %}inert{% endunless %}
                >
                  <div class="sp-faq__panel-inner">
                    {%- if answer_stripped != blank -%}
                      <div class="sp-faq__answer rte">
                        {{ block.settings.answer }}
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- elsif request.design_mode -%}
        <div class="sp-faq__empty-state">
          Add FAQ item blocks to display frequently asked questions.
        </div>
      {%- endif -%}
    </div>
{% render 'sp-section-hierarchy-close' %}

<script src="{{ 'sp-faq.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "SP FAQ",
  "tag": "section",
  "class": "section",
  "max_blocks": 15,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Frequently asked questions",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "default": "<p>Everything you need to know before you buy.</p>",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "left",
      "label": "Content alignment"
    },
    {
      "type": "checkbox",
      "id": "open_first_item",
      "default": false,
      "label": "Open first item by default"
    },
{
    "type": "header",
    "content": "Visual hierarchy"
  },
  {
    "type": "select",
    "id": "sp_surface_style",
    "label": "Surface style",
    "default": "default",
    "info": "Inverse uses the inverse color scheme from Theme settings → SP Visual hierarchy instead of the section Color scheme below.",
    "options": [
      {
        "value": "default",
        "label": "Default"
      },
      {
        "value": "alternate",
        "label": "Alternate"
      },
      {
        "value": "inverse",
        "label": "Inverse"
      },
      {
        "value": "accent",
        "label": "Accent"
      },
      {
        "value": "transparent",
        "label": "Transparent"
      }
    ]
  },
  {
    "type": "select",
    "id": "sp_width_mode",
    "label": "Width mode",
    "default": "contained",
    "options": [
      {
        "value": "contained",
        "label": "Contained"
      },
      {
        "value": "wide",
        "label": "Wide"
      },
      {
        "value": "full",
        "label": "Full width"
      },
      {
        "value": "bleed",
        "label": "Bleed"
      }
    ]
  },
  {
    "type": "select",
    "id": "sp_section_emphasis",
    "label": "Section emphasis",
    "default": "normal",
    "options": [
      {
        "value": "normal",
        "label": "Normal"
      },
      {
        "value": "elevated",
        "label": "Elevated"
      },
      {
        "value": "feature",
        "label": "Feature"
      }
    ]
  },
  {
    "type": "select",
    "id": "sp_divider_style",
    "label": "Divider",
    "default": "none",
    "options": [
      {
        "value": "none",
        "label": "None"
      },
      {
        "value": "line",
        "label": "Line"
      },
      {
        "value": "gradient",
        "label": "Gradient"
      },
      {
        "value": "fade",
        "label": "Fade"
      }
    ]
  },

    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "info": "Not applied when Surface style is set to Inverse.",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "limit": 15,
      "settings": [
        {
          "type": "text",
          "id": "question",
          "default": "How long does shipping take?",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "default": "<p>Most orders arrive within 3 to 5 business days. Express options are available at checkout.</p>",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SP FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Most orders arrive within 3 to 5 business days. Express shipping is available at checkout for faster delivery.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer a 30-day risk-free return policy. If you are not satisfied, contact our support team and we will help you with a full refund or exchange.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Does it come with a warranty?",
            "answer": "<p>Yes. Every purchase includes a limited lifetime warranty covering manufacturing defects and normal use.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Is this suitable for beginners?",
            "answer": "<p>Absolutely. The product is designed for first-time users and includes simple setup instructions so you can start right away.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How do I contact support?",
            "answer": "<p>Reach us anytime via live chat or email at support@yourstore.com. Our team typically responds within a few hours.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
