            "customer_title": "Boston, MA",
            "verified": true
          }
        }
      },
      "block_order": [
        "review-1",
        "review-2",
        "review-3"
      ],
      "settings": {
        "heading": "5,500+ verified reviews · 4.9★ average",
        "subheading": "<p>Desk setup upgrades from customers who charge smarter.</p>",
        "content_alignment": "center",
        "desktop_columns": "3",
        "mobile_layout": "swipe",
        "sp_surface_style": "alternate",
        "padding_top": 48,
        "padding_bottom": 48
      }
    },
    "sp-faq": {
      "type": "sp-faq",
      "blocks": {
        "faq-1": {
          "type": "faq_item",
          "settings": {
            "question": "Will this work with my phone case?",
            "answer": "<p>Cases under 5mm thick work with wireless charging. MagSafe cases align automatically on iPhone.</p>"
          }
        },
        "faq-2": {
          "type": "faq_item",
          "settings": {
            "question": "What is included in the box?",
            "answer": "<p>MagCharge Pro Stand, USB-C cable, and quick-start guide. Power adapter sold separately.</p>"
          }
        },
        "faq-3": {
          "type": "faq_item",
          "settings": {
            "question": "What does the 2-year warranty cover?",
            "answer": "<p>Manufacturing defects and hardware failure. Accidental damage is not covered.</p>"
          }
        },
        "faq-4": {
          "type": "faq_item",
          "settings": {
            "question": "How fast does it ship?",
            "answer": "<p>Most orders ship within 24 hours and arrive in 3–5 business days. Express options at checkout.</p>"
          }
        }
      },
      "block_order": [
        "faq-1",
        "faq-2",
        "faq-3",
        "faq-4"
      ],
      "settings": {
        "heading": "Tech specs and support",
        "subheading": "<p>Compatibility, warranty, shipping, and returns.</p>",
        "content_alignment": "center",
        "open_first_item": true,
        "padding_top": 64,
        "padding_bottom": 48
      }
    },
    "sp-cta-offer": {
      "type": "sp-cta-offer",
      "settings": {
        "heading": "Upgrade your desk setup",
        "subheading": "<p>Join 42,000+ customers charging smarter with MagCharge Pro.</p>",
        "offer_text": "$129.00 · Free shipping included",
        "button_label": "Add to cart",
        "button_link": "",
        "reassurance_text": "2-year warranty included",
        "show_badge": true,
        "badge_text": "Top rated charger",
        "card_style": "gradient",
        "sp_surface_style": "inverse",
        "sp_section_emphasis": "feature",
        "padding_top": 64,
        "padding_bottom": 64
      }
    },
    "sp-sticky-atc": {
      "type": "sp-sticky-atc",
      "settings": {
        "enable_sticky_bar": true,
        "mobile_only": true,
        "show_mobile_product_image": false,
        "show_mobile_title": false,
        "show_mobile_variant_selector": false,
        "show_product_image": true,
        "show_variant_selector": true,
        "show_compare_at_price": true,
        "button_label": "Add to cart",
        "show_price_in_button": false,
        "show_buy_now_button": false,
        "scroll_threshold": 10,
        "hide_near_footer": true,
        "background_style": "blur",
        "color_scheme": "scheme-1"
      }
    }
  },
  "order": [
    "vertical-visual-treatment",
    "main",
    "sp-trust-icons",
    "sp-benefits",
    "sp-features",
    "sp-scientific-proof",
    "sp-social-proof",
    "sp-faq",
    "sp-cta-offer",
    "sp-sticky-atc"
  ]
}
