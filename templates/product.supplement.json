        "trust-3": {
          "type": "trust_item",
          "settings": {
            "icon": "lock",
            "heading": "Secure checkout",
            "text": "<p>256-bit SSL encryption on every order.</p>"
          }
        }
      },
      "block_order": [
        "trust-1",
        "trust-2",
        "trust-3"
      ],
      "settings": {
        "heading": "",
        "subheading": "",
