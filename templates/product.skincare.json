{
  "sections": {
    "vertical-visual-treatment": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "{{ 'sp-vertical-presets.css' | asset_url | stylesheet_tag }}<script>document.documentElement.classList.add('sp-vertical-visual-neutral','sp-vertical-skincare');</script>",
        "padding_top": 0,
        "padding_bottom": 0,
        "color_scheme": "scheme-1"
      }
    },
    "main": {
      "type": "main-product",
      "blocks": {
        "vendor": {
          "type": "text",
          "settings": {
            "text": "{{ product.vendor }}",
            "text_style": "uppercase"
          }
        },
        "title": {
          "type": "title"
        },
        "caption": {
          "type": "text",
          "settings": {
            "text": "{{ product.metafields.descriptors.subtitle.value }}",
            "text_style": "subtitle"
          }
        },
        "price": {
          "type": "price"
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": true
          }
        },
        "description": {
          "type": "description"
        }
      },
      "block_order": [
        "vendor",
        "title",
        "caption",
        "price",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "description"
      ],
      "settings": {
        "enable_sticky_info": true,
        "gallery_layout": "stacked",
        "media_size": "large",
        "constrain_to_viewport": true,
        "mobile_thumbnails": "hide",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 8
      }
    },
    "sp-trust-icons": {
      "type": "sp-trust-icons",
      "blocks": {
        "trust-1": {
          "type": "trust_item",
          "settings": {
            "icon": "guarantee",
            "heading": "30-day guarantee",
            "text": "<p>Full refund if you are not completely satisfied.</p>"
          }
        },
        "trust-2": {
          "type": "trust_item",
          "settings": {
            "icon": "truck",
            "heading": "Free shipping",
            "text": "<p>Ships within 24 hours · arrives in 3–5 business days.</p>"
          }
        },
        "trust-3": {
          "type": "trust_item",
          "settings": {
            "icon": "lock",
            "heading": "Secure checkout",
            "text": "<p>256-bit SSL encryption on every order.</p>"
          }
        }
      },
      "block_order": [
        "trust-1",
        "trust-2",
        "trust-3"
      ],
      "settings": {
        "heading": "",
        "subheading": "",
        "content_alignment": "center",
        "card_style": "minimal",
        "desktop_layout": "inline",
        "desktop_columns": "3",
        "mobile_layout": "grid",
        "sp_surface_style": "default",
        "padding_top": 8,
        "padding_bottom": 32
      }
    },
    "sp-benefits": {
      "type": "sp-benefits",
      "blocks": {
        "benefit-1": {
          "type": "benefit",
          "settings": {
            "icon": "check",
            "title": "Visible radiance boost",
            "description": "<p>15% vitamin C complex helps brighten dull skin and even tone over time.</p>"
          }
        },
        "benefit-2": {
          "type": "benefit",
          "settings": {
            "icon": "truck",
            "title": "Ships within 24 hours",
            "description": "<p>Fresh batches packaged to protect active ingredients in transit.</p>"
          }
        },
        "benefit-3": {
          "type": "benefit",
          "settings": {
            "icon": "shield",
            "title": "30-day glow guarantee",
            "description": "<p>Not seeing results? Return within 30 days for a full refund.</p>"
          }
        },
        "benefit-4": {
          "type": "benefit",
          "settings": {
            "icon": "star",
            "title": "4.9★ skin approved",
            "description": "<p>Trusted by 28,000+ customers with 6,200+ verified reviews.</p>"
          }
        }
      },
      "block_order": [
        "benefit-1",
        "benefit-2",
        "benefit-3",
        "benefit-4"
      ],
      "settings": {
        "heading": "Why skin loves Radiance",
        "subheading": "<p>Dermatologist-inspired ingredients in a formula gentle enough for sensitive skin.</p>",
        "content_alignment": "center",
        "desktop_columns": "4",
        "card_style": "subtle",
        "mobile_layout": "swipe",
        "sp_surface_style": "alternate",
        "sp_divider_style": "line",
        "padding_top": 48,
        "padding_bottom": 48
      }
    },
    "sp-features": {
      "type": "sp-features",
