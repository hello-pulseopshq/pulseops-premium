            "bullet_1": "Brighter complexion in as little as 2 weeks",
            "bullet_2": "Lightweight, fast-absorbing texture",
            "bullet_3": "Works under makeup and SPF"
          }
        },
        "feature-2": {
          "type": "feature",
          "settings": {
            "title": "Hydration that lasts all day",
            "description": "<p>Multi-weight hyaluronic acid draws moisture into skin and locks it in.</p>",
            "bullet_1": "No sticky residue or pilling",
            "bullet_2": "Fragrance-free for sensitive skin",
            "bullet_3": "Cruelty-free and vegan formula"
          }
        }
      },
      "block_order": [
        "feature-1",
        "feature-2"
