      "settings": {
        "heading": "Your daily radiance ritual",
        "subheading": "<p>Apply after cleansing, before moisturizer — a simple step with compounding results.</p>",
        "content_alignment": "left",
        "image_ratio": "portrait",
        "padding_top": 64,
        "padding_bottom": 64
