    "sp-faq": {
      "type": "sp-faq",
      "blocks": {
        "faq-1": {
          "type": "faq_item",
          "settings": {
            "question": "When will I see results?",
            "answer": "<p>Most customers notice brighter, smoother skin within 2–4 weeks of consistent morning and evening use.</p>"
          }
        },
        "faq-2": {
          "type": "faq_item",
          "settings": {
            "question": "Is it safe for sensitive skin?",
            "answer": "<p>Yes. Our formula is fragrance-free and patch-test recommended. Discontinue if irritation occurs.</p>"
          }
        },
        "faq-3": {
          "type": "faq_item",
          "settings": {
            "question": "What order should I apply products?",
            "answer": "<p>Cleanse, apply Radiance Renewal Serum, then moisturizer and SPF (AM) or night cream (PM).</p>"
          }
        },
        "faq-4": {
          "type": "faq_item",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>Try it for 30 days. If you are not satisfied, contact support for a full refund or exchange.</p>"
          }
        }
