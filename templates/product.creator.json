{
  "sections": {
    "demo-visual-treatment": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "{{ 'sp-demo-presets.css' | asset_url | stylesheet_tag }}<script>document.documentElement.classList.add('sp-demo-visual-neutral','sp-demo-creator');</script>",
        "padding_top": 0,
        "padding_bottom": 0,
        "color_scheme": "scheme-1"
      }
    },
    "main": {
      "type": "main-product",
      "blocks": {
        "vendor": {
          "type": "text",
          "settings": {
            "text": "{{ product.vendor }}",
            "text_style": "uppercase"
          }
        },
        "title": {
          "type": "title"
        },
        "caption": {
          "type": "text",
          "settings": {
            "text": "{{ product.metafields.descriptors.subtitle.value }}",
            "text_style": "subtitle"
          }
        },
        "price": {
          "type": "price"
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": true
          }
        },
        "description": {
          "type": "description"
        }
      },
      "block_order": [
        "vendor",
        "title",
        "caption",
        "price",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "description"
      ],
      "settings": {
        "enable_sticky_info": true,
        "gallery_layout": "stacked",
        "media_size": "large",
        "constrain_to_viewport": true,
        "mobile_thumbnails": "hide",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 8
      }
    },
    "sp-trust-icons": {
      "type": "sp-trust-icons",
      "blocks": {
        "trust-1": {
          "type": "trust_item",
          "settings": {
            "icon": "guarantee",
            "heading": "30-day guarantee",
            "text": "<p>Full refund if you are not completely satisfied.</p>"
          }
        },
        "trust-2": {
          "type": "trust_item",
          "settings": {
            "icon": "truck",
            "heading": "Free shipping",
            "text": "<p>Ships within 24 hours · arrives in 3–5 business days.</p>"
          }
        },
        "trust-3": {
          "type": "trust_item",
          "settings": {
            "icon": "lock",
            "heading": "Secure checkout",
            "text": "<p>256-bit SSL encryption on every order.</p>"
          }
        }
      },
      "block_order": [
        "trust-1",
        "trust-2",
        "trust-3"
      ],
      "settings": {
        "heading": "",
        "subheading": "",
        "content_alignment": "center",
        "card_style": "minimal",
        "desktop_layout": "inline",
        "desktop_columns": "3",
        "mobile_layout": "grid",
        "sp_surface_style": "default",
        "padding_top": 8,
        "padding_bottom": 32
      }
    },
